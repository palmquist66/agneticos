---
import { Image } from 'astro:assets';
import { business } from '../data/business';
import logo from '../assets/images/brand/Healthy-Paws-Animal-Hospital-logo-1-2.png';

const currentPath = Astro.url.pathname;

// Top-level nav mirrors the live site: About Us / Our Team / Services / Resources & Education / Contact Us
const navItems = [
  {
    label: 'About Us',
    href: '/about/',
    children: [
      { label: 'About Us', href: '/about/' },
      { label: 'Why Choose Us', href: '/why-choose-us/' },
      { label: 'Transparency', href: '/transparency/' },
      { label: 'Your Pet\'s Experience', href: '/your-pets-experience/' },
      { label: 'Your First Visit', href: '/your-first-visit/' },
      { label: 'Take a Tour', href: '/hospital-tour/' },
    ],
  },
  {
    label: 'Our Team',
    href: '/meet-the-team/',
    children: [
      { label: 'Meet the Team', href: '/meet-the-team/' },
      { label: 'Reviews', href: '/reviews/' },
      { label: 'Careers', href: '/careers/' },
    ],
  },
  {
    label: 'Services',
    href: '/services/',
    children: [
      { label: 'Puppy & Kitten Care', href: '/general-care-lake-in-the-hills-il/' },
      { label: 'Adult Care', href: '/pet-adult-care-in-the-hills-il/' },
      { label: 'Senior Care', href: '/senior-pet-care-lake-in-the-hills-il/' },
      { label: 'Fearful Friends', href: '/behavioral-health/' },
      { label: 'End of Life Care', href: '/end-of-life-care/' },
      { label: 'Dental Care', href: '/dental-care/' },
      { label: 'Surgery', href: '/surgery/' },
      { label: 'Spay & Neuter', href: '/spay-neuter-lake-in-the-hills-il/' },
    ],
  },
  {
    label: 'Areas We Serve',
    href: '/areas-we-serve/',
    children: [
      { label: 'Lake in the Hills', href: '/areas-we-serve/' },
      { label: 'Algonquin', href: '/veterinarian-algonquin-il/' },
      { label: 'Cary', href: '/veterinarian-cary-il/' },
      { label: 'Crystal Lake', href: '/veterinarian-crystal-lake-il/' },
      { label: 'Huntley', href: '/veterinarian-huntley-il/' },
      { label: 'Village of Lakewood', href: '/veterinarian-village-of-lakewood-il/' },
      { label: 'Woodstock', href: '/veterinarian-woodstock-il/' },
    ],
  },
  {
    label: 'Resources & Education',
    href: '/info-center/',
    children: [
      { label: 'Education', href: '/education/' },
      { label: 'Pricing Transparency', href: '/pricing-transparency/' },
      { label: 'Prescription Refills', href: '/prescription-refills/' },
      { label: 'Pet Health Articles', href: '/info-center/' },
      { label: 'Pet Portal', href: '/our-app/' },
      { label: 'Specialty & Emergency Partners', href: '/specialty-partners/' },
      { label: 'Local Pet Services', href: '/local-pet-services/' },
    ],
  },
];
---

<header class="bg-white border-b border-hpah-gray sticky top-0 z-50">
  <!-- Main nav -->
  <nav class="container py-4" aria-label="Main navigation">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex-shrink-0" aria-label="Healthy Paws Animal Hospital - Home">
        <Image
          src={logo}
          alt="Healthy Paws Animal Hospital logo"
          width={220}
          class="h-14 w-auto"
          loading="eager"
        />
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          <div class="relative group">
            <a
              href={item.href}
              class:list={[
                'px-3 py-2 text-sm font-semibold rounded-md transition-colors inline-flex items-center gap-1',
                currentPath.startsWith(item.href)
                  ? 'text-hpah-green'
                  : 'text-hpah-text hover:text-hpah-green',
              ]}
            >
              {item.label}
              {item.children && (
                <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>
            {item.children && (
              <div class="absolute left-0 top-full pt-2 invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-200">
                <div class="bg-white rounded-lg shadow-xl border border-hpah-gray py-2 min-w-[220px]">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class:list={[
                        'block px-4 py-2 text-sm hover:bg-hpah-green-light transition-colors',
                        currentPath === child.href ? 'text-hpah-green font-semibold' : 'text-hpah-text',
                      ]}
                    >
                      {child.label}
                    </a>
                  ))}
                </div>
              </div>
            )}
          </div>
        ))}
        <a href="/contact/" class="btn-primary ml-3 text-sm">
          Contact Us
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-md hover:bg-gray-100"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile nav -->
    <div id="mobile-menu" class="hidden lg:hidden mt-4 pb-4 border-t border-hpah-gray pt-4">
      {navItems.map((item) => (
        <div>
          <a
            href={item.href}
            class="block py-2 text-base font-semibold text-hpah-text hover:text-hpah-green"
          >
            {item.label}
          </a>
          {item.children && (
            <div class="pl-4 pb-2">
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class="block py-1.5 text-sm text-hpah-text-light hover:text-hpah-green"
                >
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
      <a href="/contact/" class="btn-primary mt-4 w-full justify-center">
        Contact Us
      </a>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
  });
</script>
