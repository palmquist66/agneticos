---
import FAQSchema from './FAQSchema.astro';

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQ[];
  heading?: string;
}

const { faqs, heading = 'Frequently Asked Questions' } = Astro.props;
---

<section class="py-16 bg-hpah-bg-warm">
  <div class="container max-w-3xl">
    <h2 class="text-center mb-10">{heading}</h2>
    <div class="space-y-4">
      {faqs.map((faq, i) => (
        <details class="group bg-white rounded-lg border border-gray-200 overflow-hidden">
          <summary class="flex justify-between items-center cursor-pointer p-5 font-semibold text-hpah-text hover:text-hpah-green transition-colors list-none">
            <span>{faq.question}</span>
            <svg class="w-5 h-5 flex-shrink-0 ml-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-5 pb-5 text-hpah-text-light leading-relaxed">
            {faq.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
  <FAQSchema faqs={faqs} />
</section>
