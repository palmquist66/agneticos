---
import { Image } from 'astro:assets';
import { business } from '../data/business';
import readyImg from '../assets/images/wp-import/Happy-Dog.jpg';

const currentYear = new Date().getFullYear();

// Hours rendered to match the live site grouping
const hoursRows = [
  { days: 'Monday & Tuesday', time: '7:00 am – 6:00 pm' },
  { days: 'Wednesday', time: '8:00 am – 6:00 pm' },
  { days: 'Thursday', time: '10:00 am – 6:00 pm' },
  { days: 'Friday', time: '7:00 am – 5:00 pm' },
  { days: 'Saturday & Sunday', time: 'Closed' },
];
---

<footer>
  <!-- Ready to Visit? -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="mb-4">Ready to Visit?</h2>
          <p class="text-hpah-text-light mb-6">
            We proudly serve the clients of Village of Lakewood, Bull Valley, Crystal Lake, Algonquin, Woodstock, McHenry, Cary, Lake in the Hills, Huntley, and beyond. We look forward to helping you and your pet! If you would like to schedule an appointment, please click the button below.
          </p>
          <a href="/schedule/" class="btn-primary">Book Appointment</a>
        </div>
        <div class="overflow-hidden rounded-lg">
          <Image src={readyImg} alt="A happy dog relaxing" widths={[480, 720, 960]} class="w-full h-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <!-- Contact form -->
  <section class="py-20" style="background: rgba(72,170,67,0.16);">
    <div class="container max-w-2xl">
      <div class="text-center mb-8">
        <h2 class="mb-3">Contact Us</h2>
        <p class="text-hpah-text-light">
          Please complete the form below, and a member of our team will get back to you as quickly as possible. If your pet needs immediate treatment and it's during normal business hours, please contact the office at <a href={`tel:${business.phoneRaw}`} class="text-hpah-green font-semibold">{business.phone}</a>.
        </p>
      </div>
      <form action={`mailto:${business.email}`} method="post" enctype="text/plain" class="bg-white rounded-lg p-8 border border-hpah-gray space-y-5">
        <div>
          <label class="block text-sm font-semibold text-hpah-text mb-2" for="footer-name">Name <span class="text-hpah-green">*</span></label>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <input id="footer-name" name="First Name" type="text" placeholder="First" required class="w-full border border-hpah-gray rounded-md px-4 py-2.5 focus:outline-none focus:border-hpah-green" />
            <input name="Last Name" type="text" placeholder="Last" class="w-full border border-hpah-gray rounded-md px-4 py-2.5 focus:outline-none focus:border-hpah-green" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-semibold text-hpah-text mb-2" for="footer-email">Email <span class="text-hpah-green">*</span></label>
          <input id="footer-email" name="Email" type="email" required class="w-full border border-hpah-gray rounded-md px-4 py-2.5 focus:outline-none focus:border-hpah-green" />
        </div>
        <div>
          <label class="block text-sm font-semibold text-hpah-text mb-2" for="footer-phone">Phone</label>
          <input id="footer-phone" name="Phone" type="tel" class="w-full border border-hpah-gray rounded-md px-4 py-2.5 focus:outline-none focus:border-hpah-green" />
        </div>
        <div>
          <label class="block text-sm font-semibold text-hpah-text mb-2" for="footer-message">How can we help you? <span class="text-hpah-green">*</span></label>
          <textarea id="footer-message" name="Message" rows="4" required class="w-full border border-hpah-gray rounded-md px-4 py-2.5 focus:outline-none focus:border-hpah-green"></textarea>
        </div>
        <button type="submit" class="btn-primary w-full justify-center">Submit</button>
      </form>
    </div>
  </section>

  <!-- We're Here to Help -->
  <section class="bg-hpah-green-light py-16 border-t border-hpah-gray">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-3xl mb-3">We're Here to Help</h2>
        <p class="text-hpah-text-light">Get in touch! A member of our team will reach out shortly.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-4xl mx-auto">
        <!-- Location -->
        <div class="text-center md:text-left">
          <h3 class="text-lg font-bold text-hpah-green mb-3" style="font-family: var(--font-narrow);">Location</h3>
          <address class="not-italic text-hpah-text-light space-y-1">
            <p class="font-semibold text-hpah-text">{business.name}</p>
            <p>
              <a
                href={`https://www.google.com/maps/place/${encodeURIComponent(business.address.full)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:text-hpah-green"
              >
                {business.address.street} {business.address.note}<br />
                {business.address.city}, {business.address.state} {business.address.zip}
              </a>
            </p>
            <p>
              <a href={`tel:${business.phoneRaw}`} class="font-bold text-hpah-green hover:text-hpah-green-accent">
                {business.phone}
              </a>
            </p>
          </address>
        </div>

        <!-- Contact Information -->
        <div class="text-center md:text-left">
          <h3 class="text-lg font-bold text-hpah-green mb-3" style="font-family: var(--font-narrow);">Contact Information</h3>
          <div class="text-hpah-text-light space-y-1">
            <p>Email: <a href={`mailto:${business.email}`} class="hover:text-hpah-green">{business.email}</a></p>
            <p>Fax: {business.fax}</p>
          </div>
        </div>

        <!-- Hours -->
        <div class="text-center md:text-left">
          <h3 class="text-lg font-bold text-hpah-green mb-3" style="font-family: var(--font-narrow);">Hours</h3>
          <dl class="text-hpah-text-light space-y-1">
            {hoursRows.map((row) => (
              <div>
                <dt class="font-semibold text-hpah-text inline">{row.days}:</dt>
                <dd class="inline"> {row.time}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Areas We Serve -->
  <div class="bg-hpah-green-light border-t border-hpah-gray py-6">
    <div class="container text-center">
      <h3 class="text-base font-bold text-hpah-green mb-3" style="font-family: var(--font-narrow);">Areas We Serve</h3>
      <div class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm">
        <a href="/areas-we-serve/" class="text-hpah-text hover:text-hpah-green">Lake in the Hills</a>
        <a href="/veterinarian-algonquin-il/" class="text-hpah-text hover:text-hpah-green">Algonquin</a>
        <a href="/veterinarian-huntley-il/" class="text-hpah-text hover:text-hpah-green">Huntley</a>
        <a href="/veterinarian-crystal-lake-il/" class="text-hpah-text hover:text-hpah-green">Crystal Lake</a>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="bg-hpah-text text-white/80">
    <div class="container py-5 flex flex-col md:flex-row justify-between items-center gap-3 text-sm">
      <p class="mb-0">&copy; {currentYear} {business.name}</p>
      <div class="flex gap-6">
        <a href="/privacy-policy/" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/accessibility/" class="hover:text-white transition-colors">Accessibility Statement</a>
      </div>
    </div>
  </div>
</footer>
