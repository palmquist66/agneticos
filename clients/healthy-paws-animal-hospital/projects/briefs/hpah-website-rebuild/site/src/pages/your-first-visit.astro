---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business } from '../data/business';

import heroImage from '../assets/images/services/7-YOUR-FIRST-VISIT-Gus-El-2.jpg';
---

<BaseLayout
  title="Your First Visit | Healthy Paws Animal Hospital"
  description="Preparing for your pet's first vet visit at Healthy Paws Animal Hospital in Lake in the Hills, IL. Learn what to bring and what to expect during a comprehensive exam."
>
  <!-- Hero Banner -->
  <section class="hero-banner">
    <div class="absolute inset-0">
      <Image
        src={heroImage}
        alt="Gus Gus and Eleanor welcoming you to Healthy Paws Animal Hospital"
        class="w-full h-full object-cover"
        loading="eager"
        widths={[640, 960, 1280, 1920]}
      />
      <div class="absolute inset-0" style="background: rgba(0,0,0,0.4);"></div>
    </div>
    <div class="container relative z-10 text-center">
      <h1 class="text-4xl lg:text-5xl text-white mb-4">Your First Visit</h1>
      <p class="text-lg text-white/90 max-w-2xl mx-auto">
        Our resources will help you prepare for your pet's vet visit. They include comprehensive exams, training tips, and parasite protection recommendations.
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-20">
    <div class="container" style="max-width: 800px;">
      <h2 class="mb-6">Preparing for Your Pet's First Vet Visit: A Comprehensive Guide and Overview</h2>
      <p class="text-hpah-text-light leading-relaxed mb-6">
        Preparing for your pet's initial visit to the <a href="/meet-the-team/">veterinarian</a> may feel overwhelming, but we've compiled a comprehensive list of information and resources to guide you through the process.
      </p>
      <p class="text-hpah-text-light leading-relaxed mb-6">
        During the first appointment, we aim to gather essential details about your pet's history, overall health, diet, and training. This is also an opportunity to raise any questions or express concerns. Our experienced veterinarian will conduct a thorough examination, checking your pet from nose to tail. This includes assessing for heart murmurs, ear infections, and parasites. In addition to the examination, your vet will offer valuable insights into pet-proofing your home, provide training assistance, and recommend effective parasite protection measures. The goal of <a href="/about/">Healthy Paws Animal Hospital</a> is to ensure your pet's well-being and address any needs or inquiries you may have during this initial visit.
      </p>

      <h3 class="text-xl font-bold mb-4 mt-10">Before Your First Appointment</h3>
      <ol class="space-y-4 list-decimal list-inside text-hpah-text-light leading-relaxed">
        <li>
          Ensure you have all the necessary items before heading to the appointment:
          <ul class="ml-8 mt-2 space-y-1 list-disc list-inside">
            <li>Adoption or purchase records for your pet</li>
            <li>Existing medical history</li>
            <li>List of current medications and supplements</li>
            <li>Current feeding schedule and the brand of food you use</li>
            <li>List of questions for your veterinarian</li>
          </ul>
        </li>
        <li>If required, gather stool or urine samples.</li>
        <li>For dog owners, make sure your dog is comfortable on a short leash. For cat owners, bring an appropriate carrier.</li>
        <li>Bring your pet's favorite treats to keep them content and distracted during the visit. If the staff instructs you to do so prior to the visit, ensure your pet fasts.</li>
      </ol>

      <div class="mt-10 text-center">
        <a href="/forms/" class="btn-primary">Initial Visit History Form</a>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
