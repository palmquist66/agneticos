---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business } from '../data/business';

import heroImg from '../assets/images/hero/banner-img-5.jpg';
---

<BaseLayout
  title="Veterinary Jobs | Healthy Paws Animal Hospital"
  description="Join our veterinary team at Healthy Paws Animal Hospital in Lake in the Hills, IL. Apply for open positions today."
>
  <!-- Hero Banner -->
  <section class="hero-banner">
    <div class="absolute inset-0">
      <Image
        src={heroImg}
        alt="Healthy Paws Animal Hospital team"
        class="w-full h-full object-cover"
        loading="eager"
        widths={[640, 960, 1280, 1920]}
      />
      <div class="absolute inset-0" style="background: rgba(0,0,0,0.4);"></div>
    </div>
    <div class="container relative z-10 text-center">
      <h1 class="text-4xl lg:text-5xl text-white mb-4">Veterinary Jobs</h1>
      <p class="text-lg text-white/90 max-w-2xl mx-auto">
        Join our <a href="/meet-the-team/" class="text-white underline">veterinary team</a> at <a href="/about/" class="text-white underline">Healthy Paws Animal Hospital</a>.
      </p>
    </div>
  </section>

  <!-- Application Section -->
  <section class="py-16 lg:py-20">
    <div class="container" style="max-width: 700px;">
      <h2 class="text-3xl mb-6 text-center">Ready to start your veterinary career?</h2>

      <div class="bg-hpah-green-light rounded-lg p-8 mb-8">
        <h3 class="text-xl font-bold mb-4">What we'll need from you:</h3>
        <ul class="space-y-3 text-hpah-text-light">
          <li class="flex items-start gap-3">
            <span class="text-hpah-green font-bold mt-0.5">&#10003;</span>
            <span>Your name, email, and phone number</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-hpah-green font-bold mt-0.5">&#10003;</span>
            <span>What position you are interested in</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-hpah-green font-bold mt-0.5">&#10003;</span>
            <span>Cover letter (optional)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-hpah-green font-bold mt-0.5">&#10003;</span>
            <span>Resume</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-hpah-green font-bold mt-0.5">&#10003;</span>
            <span>Any additional information you'd like us to know</span>
          </li>
        </ul>
      </div>

      <div class="text-center">
        <a
          href="https://healthypawsanimalhospital.com/lake-in-the-hills-il-veterinary-jobs/#onlineform"
          class="btn-primary text-lg"
          target="_blank"
          rel="noopener"
        >
          Apply Now
        </a>
      </div>
    </div>
  </section>

  <CTA heading="Learn About Our Team" text="See who you'd be working with — our team is what makes Healthy Paws different." />
</BaseLayout>
