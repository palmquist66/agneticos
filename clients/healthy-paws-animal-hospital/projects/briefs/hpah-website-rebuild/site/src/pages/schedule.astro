---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business } from '../data/business';

const hours = Object.entries(business.hours).map(([day, time]) => ({
  day: day.charAt(0).toUpperCase() + day.slice(1),
  time,
}));

const callChecklist = [
  'Your pet\'s name, age, breed, and weight',
  'The reason for the visit (wellness, illness, injury, etc.)',
  'Any medications your pet is currently taking',
  'Your preferred day and time',
  'Previous veterinary records (if you\'re a new client)',
];
---

<BaseLayout
  title="Schedule an Appointment | Healthy Paws Animal Hospital"
  description={`Schedule a veterinary appointment at Healthy Paws Animal Hospital in Lake in the Hills, IL. Call ${business.phone} to book your visit today.`}
>
  <!-- Page Header -->
  <section class="bg-hpah-green-light py-16">
    <div class="container">
      <h1 class="text-4xl lg:text-5xl mb-4">Schedule an Appointment</h1>
      <p class="text-lg text-hpah-text-light max-w-2xl">
        We look forward to meeting you and your pet. Scheduling is quick and easy — just give us a call
        and our friendly front desk team will find a time that works for you.
      </p>
    </div>
  </section>

  <!-- Phone CTA -->
  <section class="py-16">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <div class="bg-hpah-green-light rounded-2xl p-10 border border-hpah-green/20">
          <svg class="w-16 h-16 text-hpah-green mx-auto mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <h2 class="text-3xl mb-4">Call Us to Schedule</h2>
          <p class="text-hpah-text-light text-lg mb-6">
            The best way to schedule an appointment is to give us a call. Our team will help you find a convenient time
            and answer any questions you might have before your visit.
          </p>
          <a href={`tel:${business.phoneRaw}`} class="btn-primary text-xl px-10 py-4">
            Call {business.phone}
          </a>
          <p class="text-sm text-hpah-text-light mt-4">
            You can also email us at
            <a href={`mailto:${business.email}`} class="text-hpah-blue hover:text-hpah-green font-semibold">{business.email}</a>
            for non-urgent scheduling requests.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- What to Have Ready + Hours -->
  <section class="py-16 bg-hpah-bg-warm">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 max-w-5xl mx-auto">
        <!-- What to Have Ready -->
        <div>
          <h2 class="text-2xl mb-6">What to Have Ready When You Call</h2>
          <p class="text-hpah-text-light mb-6">
            To help us schedule the right type and length of appointment for your pet, it's helpful to have
            the following information handy when you call:
          </p>
          <ul class="space-y-4">
            {callChecklist.map((item) => (
              <li class="flex items-start gap-3">
                <svg class="w-6 h-6 text-hpah-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Hours -->
        <div>
          <h2 class="text-2xl mb-6">Office Hours</h2>
          <p class="text-hpah-text-light mb-6">
            We schedule appointments during our regular office hours. We do our best to accommodate same-day
            appointments for urgent needs — just let us know when you call.
          </p>
          <div class="bg-white rounded-lg border border-gray-200 overflow-hidden">
            <table class="w-full">
              <tbody>
                {hours.map((row, i) => (
                  <tr class:list={[i % 2 === 0 ? 'bg-white' : 'bg-hpah-bg-warm']}>
                    <td class="px-6 py-3 font-bold">{row.day}</td>
                    <td class:list={['px-6 py-3 text-right', row.time === 'Closed' ? 'text-hpah-text-light italic' : '']}>
                      {row.time}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- New Patient Info -->
  <section class="py-16">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl mb-6 text-center">New Patient Information</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="bg-white rounded-lg p-8 border border-gray-200">
            <h3 class="text-lg font-bold mb-3">Your First Visit</h3>
            <p class="text-hpah-text-light">
              We recommend arriving about 10 minutes early for your first appointment.
              This gives us time to set up your pet's records and learn about their
              medical history, lifestyle, and any concerns you have. Your first visit
              typically takes 45 minutes to an hour so we can be thorough.
            </p>
          </div>
          <div class="bg-white rounded-lg p-8 border border-gray-200">
            <h3 class="text-lg font-bold mb-3">What to Bring</h3>
            <ul class="text-hpah-text-light space-y-2">
              <li class="flex items-start gap-2">
                <span class="text-hpah-green font-bold">-</span>
                <span>Any previous veterinary records or vaccination history</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-hpah-green font-bold">-</span>
                <span>A list of current medications and supplements</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-hpah-green font-bold">-</span>
                <span>Your pet's current food brand and feeding schedule</span>
              </li>
              <li class="flex items-start gap-2">
                <span class="text-hpah-green font-bold">-</span>
                <span>Any questions or concerns — write them down so you don't forget</span>
              </li>
            </ul>
          </div>
          <div class="bg-white rounded-lg p-8 border border-gray-200">
            <h3 class="text-lg font-bold mb-3">Our Low-Stress Approach</h3>
            <p class="text-hpah-text-light">
              We are a practice dedicated to gentle, low-stress care, which means we've designed every part
              of the visit to reduce stress for your pet. Your pet goes directly to the
              exam room — no crowded lobby, no anxious waiting. We use gentle handling
              techniques, calming environments, and treats to make the experience positive.
            </p>
          </div>
          <div class="bg-white rounded-lg p-8 border border-gray-200">
            <h3 class="text-lg font-bold mb-3">What to Expect</h3>
            <p class="text-hpah-text-light">
              We take the time to explain everything we're doing and why. You'll never
              feel rushed or pressured. Our goal is for you to leave feeling confident
              and informed about your pet's health, with a clear understanding of any
              recommendations and their reasoning.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA heading="Ready to Schedule?" text={`Call ${business.phone} today and let us find the perfect time for your pet's visit.`} />
</BaseLayout>
