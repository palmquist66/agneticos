---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business, team } from '../data/business';

// Hero image
import teamHero from '../assets/images/hero/Veterinary-team-banner.jpg';

// Vet headshot imports
import drBurgessPhoto from '../assets/images/team/Dr.-Burgess2.jpg';
import drHaslittPhoto from '../assets/images/team/Dr.-Haslitt.png';
import drMosierPhoto from '../assets/images/team/Dr.-Mosier.jpg';

// Staff headshot imports
import brookePhoto from '../assets/images/team/Brooke.jpg';
import cheriPhoto from '../assets/images/team/Cheri-1.jpg';
import amandaPhoto from '../assets/images/team/Amanda-Schwarz-1.jpg';
import heatherPhoto from '../assets/images/team/Heather-8.png';
import lizPhoto from '../assets/images/team/Liz-Hartzheim.jpg';
import erynPhoto from '../assets/images/team/Eryn.jpg';
import sarahPhoto from '../assets/images/team/Sarah-Prigge.jpg';
import anastasiaPhoto from '../assets/images/team/Anastasiia-Gusarova.jpg';
import kadeePhoto from '../assets/images/team/Kadee-Palmquist.jpg';
import carolPhoto from '../assets/images/team/Carol-1.jpg';
import brendaPhoto from '../assets/images/team/Brenda-1.jpg';
import kristenPhoto from '../assets/images/team/Kristen-1.jpg';
import annaPhoto from '../assets/images/team/ANNA.jpg';
import jeanMariePhoto from '../assets/images/team/Jean-Marie-1.jpg';
import johnPhoto from '../assets/images/team/John-1-1.jpg';

// Clinic cat imports
import gusPhoto from '../assets/images/cats/Gus.jpg';
import eleanorPhoto from '../assets/images/cats/Eleanor-cat.jpg';
import catsGroupPhoto from '../assets/images/misc/hugging-1-1.jpg';

const vetPhotos: Record<string, ImageMetadata> = {
  'Dr.-Burgess2.jpg': drBurgessPhoto,
  'Dr.-Haslitt.png': drHaslittPhoto,
  'Dr.-Mosier.jpg': drMosierPhoto,
};

const staffPhotos: Record<string, ImageMetadata> = {
  'Brooke.jpg': brookePhoto,
  'Cheri-1.jpg': cheriPhoto,
  'Amanda-Schwarz-1.jpg': amandaPhoto,
  'Heather-8.png': heatherPhoto,
  'Liz-Hartzheim.jpg': lizPhoto,
  'Eryn.jpg': erynPhoto,
  'Sarah-Prigge.jpg': sarahPhoto,
  'Anastasiia-Gusarova.jpg': anastasiaPhoto,
  'Kadee-Palmquist.jpg': kadeePhoto,
  'Carol-1.jpg': carolPhoto,
  'Brenda-1.jpg': brendaPhoto,
  'Kristen-1.jpg': kristenPhoto,
  'ANNA.jpg': annaPhoto,
  'Jean-Marie-1.jpg': jeanMariePhoto,
  'John-1-1.jpg': johnPhoto,
};

const catPhotos: Record<string, ImageMetadata> = {
  'Gus.jpg': gusPhoto,
  'Eleanor-cat.jpg': eleanorPhoto,
};

// Vet bio anchors: WP links to anchor bios on the live site — no inline bio text shown here.
const vetBioAnchors: Record<string, string> = {
  'dr-burgess': 'karen',
  'dr-haslitt': 'Tracey',
  'dr-mosier': 'Megan',
};

// Group staff by role category
const cvts = team.staff.filter((m) => m.role === 'Certified Veterinary Technician');
const assistants = team.staff.filter((m) => m.role === 'Veterinary Assistant');
const coordinators = team.staff.filter((m) => m.role === 'Care Coordinator');
const admin = team.staff.filter((m) => !['Certified Veterinary Technician', 'Veterinary Assistant', 'Care Coordinator'].includes(m.role));

const staffGroups = [
  { title: 'Certified Veterinary Technicians', members: cvts },
  { title: 'Veterinary Assistants', members: assistants },
  { title: 'Care Coordinators', members: coordinators },
  { title: 'Administration', members: admin },
];

const personSchemas = team.vets.map((vet) => ({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: vet.fullName,
  jobTitle: vet.role,
  worksFor: {
    '@type': 'VeterinaryCare',
    name: business.name,
    url: business.website,
  },
  ...(vet.education
    ? {
        alumniOf: {
          '@type': 'EducationalOrganization',
          name: vet.education.split(',')[0],
        },
      }
    : {}),
}));
---

<BaseLayout
  title="Meet the Team | Healthy Paws Animal Hospital"
  description="Meet the veterinary team at Healthy Paws Animal Hospital in Lake in the Hills, IL — Dr. Burgess, Dr. Haslitt, and Dr. Mosier. Committed to gentle, low-stress, personal, educational care."
>
  <!-- Person Schema -->
  <Fragment slot="schema">
    {personSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>

  <!-- Hero Banner -->
  <section class="hero-banner">
    <div class="absolute inset-0">
      <Image
        src={teamHero}
        alt="The veterinary team at Healthy Paws Animal Hospital"
        class="w-full h-full object-cover"
        loading="eager"
        widths={[640, 960, 1280, 1920]}
      />
      <div class="absolute inset-0" style="background: rgba(0,0,0,0.4);"></div>
    </div>
    <div class="container relative z-10 text-center">
      <h1 class="text-4xl lg:text-5xl text-white mb-4">Meet Our Veterinary Team</h1>
      <p class="text-lg text-white/90 max-w-2xl mx-auto">
        We hope to see you soon! Discover <a href="/about/" class="text-white underline">Healthy Paws Animal Hospital's</a> fantastic team and why we love what we do.
      </p>
    </div>
  </section>

  <!-- Team Intro -->
  <section class="py-16">
    <div class="container" style="max-width: 900px;">
      <h2 class="text-center mb-6">Our team is, hands down, what makes us most different.</h2>
      <p class="text-lg text-hpah-text-light leading-relaxed text-center">
        Our veterinary team at <a href="/about/">Healthy Paws Animal Hospital</a> embodies a compassionate and dedicated group of professionals committed to the well-being of your furry companions. With a wealth of expertise and a genuine love for animals, each team member plays a crucial role in providing quality care for pets. We foster a warm and welcoming environment, recognizing the importance of building trust and rapport with both pets and their owners.
      </p>
    </div>
  </section>

  <!-- Veterinarians (card grid) -->
  <section class="py-20">
    <div class="container max-w-5xl">
      <h2 class="text-center mb-12">Our Veterinarians</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {team.vets.map((vet, index) => (
          <div class="divi-card bg-white text-center">
            {vetPhotos[vet.photo] ? (
              <Image
                src={vetPhotos[vet.photo]}
                alt={`${vet.fullName}, ${vet.role} at Healthy Paws Animal Hospital`}
                width={360}
                class="w-full aspect-square object-cover"
                loading={index === 0 ? 'eager' : 'lazy'}
              />
            ) : (
              <div class="w-full aspect-square bg-gray-200 flex items-center justify-center">
                <span class="text-5xl font-bold text-gray-400 font-narrow">
                  {vet.name.replace('Dr. ', '').split(' ').map((n: string) => n[0]).join('').toUpperCase()}
                </span>
              </div>
            )}
            <div class="p-6">
              <h3 class="text-xl mb-1">{vet.fullName}</h3>
              <p class="text-hpah-green font-bold text-sm mb-3">{vet.role}</p>
              {vet.education && (
                <p class="text-xs text-hpah-text-light mb-3">{vet.education}</p>
              )}
              <a
                href={`https://healthypawsanimalhospital.com/veterinarian-lake-in-the-hills-il/#${vetBioAnchors[vet.slug] || vet.slug}`}
                class="text-hpah-green text-sm font-bold hover:text-hpah-green transition-colors"
                target="_blank"
                rel="noopener noreferrer"
              >
                Read Bio &rarr;
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Staff Section (green tint background, grouped by role) -->
  <section class="py-20" style="background: rgba(71,128,51,0.04);">
    <div class="container max-w-5xl">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="mb-4">Our Staff</h2>
      </div>

      {staffGroups.map((group) => group.members.length > 0 && (
        <div class="mb-12 last:mb-0">
          <h3 class="text-xl mb-6 text-center text-hpah-green">{group.title}</h3>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-6">
            {group.members.map((member) => (
              <div class="text-center">
                {staffPhotos[member.photo] ? (
                  <Image
                    src={staffPhotos[member.photo]}
                    alt={`${member.name}, ${member.role} at Healthy Paws Animal Hospital`}
                    width={180}
                    class="w-full aspect-square object-cover rounded-lg mb-3"
                  />
                ) : (
                  <div class="w-full aspect-square bg-gray-200 rounded-lg flex items-center justify-center mb-3">
                    <span class="text-2xl font-bold text-gray-400">
                      {member.name.split(' ').map((n: string) => n[0]).join('').toUpperCase()}
                    </span>
                  </div>
                )}
                <p class="font-bold text-sm">{member.name}</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Clinic Cats -->
  <section class="py-20">
    <div class="container max-w-4xl">
      <div class="text-center mb-8">
        <h2 class="mb-4">Our Cats</h2>
      </div>

      <!-- Group photo + intro -->
      <div class="flex flex-col md:flex-row gap-8 items-start mb-12">
        <div class="md:w-1/3">
          <Image
            src={catsGroupPhoto}
            alt="Clinic cats hugging on a shelf at Healthy Paws Animal Hospital"
            width={400}
            class="w-full rounded-lg"
          />
        </div>
        <div class="md:w-2/3">
          <h3 class="text-xl mb-3">Clinic Cats</h3>
          <p class="text-sm text-hpah-green font-bold mb-3">Masters of Mischief</p>
          <p class="text-hpah-text-light leading-relaxed">
            We have had an incredible run of GREAT clinic cats. It started with Vincent, a great ambassador who was with us for 6+ years. Vincent would sit in the front lobby and 'allow' all who entered to pet him. He left us in early 2016. A great loss for our team! April 2016 brought feline friends to Healthy Paws Animal Hospital, Gus Gus (orange longhaired) and Eleanor (gray shorthaired). They have learned the ropes of being clinic cats, sauntering around in spite of barking, vacuums, and, at times, mayhem. Be sure to pet our friendly, mischievous felines on your next visit!
          </p>
        </div>
      </div>

      <!-- Individual cat cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-3xl mx-auto">
        <div class="divi-card bg-white">
          <Image
            src={gusPhoto}
            alt="Gus Gus, clinic cat at Healthy Paws Animal Hospital"
            width={400}
            class="w-full"
          />
          <div class="p-6">
            <h3 class="text-xl mb-3">Gus Gus</h3>
            <p class="text-sm text-hpah-text-light leading-relaxed">
              Gus Gus has a more regal presence and is ever the socialite, making sure everyone receives a proper welcome. Gus is down-to-earth and a hanging-out kind of guy. While he does not seek adults out, he has a special place in his heart for kids. And if you see a paw under your exam room door someday, it is his! Gus' favorite pastimes are playing with his Turbo Scratcher toy, eating food from his SlimCat Toy, and carrying around his favorite mouse.
            </p>
          </div>
        </div>
        <div class="divi-card bg-white">
          <Image
            src={eleanorPhoto}
            alt="Eleanor, clinic cat at Healthy Paws Animal Hospital"
            width={400}
            class="w-full"
          />
          <div class="p-6">
            <h3 class="text-xl mb-3">Eleanor</h3>
            <p class="text-sm text-hpah-text-light leading-relaxed">
              Eleanor could be described as goofy and presumptuous. A real queen bee, she demands attention and solitude based on her mood and is known for "putting herself to bed" in a variety of cabinets, drawers, and rooms. And oh, the look if you interrupt her beauty sleep! Her favorite pastime is being in people's business and sitting in laps.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA heading="Meet Us in Person" text="Schedule a visit and experience the warmth and expertise of the Healthy Paws team firsthand." />
</BaseLayout>
