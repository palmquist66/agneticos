---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business } from '../data/business';

import heroImg from '../assets/images/hero/banner-img-12.jpg';
---

<BaseLayout
  title="Patient Health Form | Healthy Paws Animal Hospital"
  description="Complete your Patient Health Form before your visit to Healthy Paws Animal Hospital in Lake in the Hills, IL — a pre-visit questionnaire for new and returning patients."
>
  <!-- Hero Banner -->
  <section class="hero-banner">
    <div class="absolute inset-0">
      <Image
        src={heroImg}
        alt="Healthy Paws Animal Hospital"
        class="w-full h-full object-cover"
        loading="eager"
        widths={[640, 960, 1280, 1920]}
      />
      <div class="absolute inset-0" style="background: rgba(0,0,0,0.4);"></div>
    </div>
    <div class="container relative z-10 text-center">
      <h1 class="text-4xl lg:text-5xl text-white mb-4">Patient Health Form</h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-12">
    <div class="container max-w-3xl text-center">
      <p class="text-lg text-hpah-text-light">We're excited to see you and your pet for their upcoming exam!</p>
    </div>
  </section>

  <!-- Patient Health Form -->
  <section class="pb-20">
    <div class="container max-w-2xl">
      <div class="bg-white rounded-lg p-8 border border-gray-200 text-center">
        <h2 class="text-2xl mb-3">Patient Health Form &middot; Pre-Visit Questionnaire</h2>
        <p class="text-hpah-text-light mb-6">
          <strong>Welcome!</strong> Please select your visit type, complete the form, and click <strong>Submit Form</strong>. Your responses go directly to our team.
        </p>
        <p class="text-sm text-hpah-text-light mb-6">
          Our secure online pre-visit form is being set up for the new site. In the meantime, call us at
          <a href="tel:+18153225400" class="text-hpah-green font-semibold">(815) 322-5400</a>
          and we'll complete it with you.
        </p>
        <a href="/schedule/" class="btn-primary text-lg">Schedule a Visit</a>
      </div>
    </div>
  </section>

  <CTA heading="Ready to Schedule Your First Visit?" text="New patients are always welcome. Schedule your appointment and we'll walk you through everything you need." />
</BaseLayout>
