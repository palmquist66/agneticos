---

<BaseLayout
  title="Info Center | Healthy Paws Animal Hospital"
  description="Pet health articles written by the Healthy Paws Animal Hospital team. Learn about allergies, medications, behavior, dental care, parasites, toxicity, and more."
>
  <!-- Hero Banner -->
  <section class="hero-banner">
    <div class="absolute inset-0">
      <Image
        src={heroImg}
        alt="Healthy Paws Animal Hospital"
        class="w-full h-full object-cover"
        loading="eager"
        widths={[640, 960, 1280, 1920]}
      />
      <div class="absolute inset-0" style="background: rgba(0,0,0,0.4);"></div>
    </div>
    <div class="container relative z-10 text-center">
      <h1 class="text-4xl lg:text-5xl text-white mb-4">Info Center</h1>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-16">
    <div class="container" style="max-width: 900px;">
      <p class="text-lg text-hpah-text-light text-center leading-relaxed">
        The <a href="/meet-the-team/">Healthy Paws Animal Hospital team</a> has written articles that will help you learn new information and improve your pet's quality of life!
      </p>
    </div>
  </section>

  <!-- Article Directory -->
  <section class="pb-20">
    <div class="container" style="max-width: 900px;">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
        {categories.map((category) => (
          <div>
            <h3 class="text-xl font-bold mb-3 text-hpah-green border-b border-gray-200 pb-2">{category.name}</h3>
            <ul class="space-y-1.5">
              {category.articles.map((article) => (
                <li>
                  <a
                    href={`https://healthypawsanimalhospital.com/${article.slug}/`}
                    class="text-hpah-blue hover:text-hpah-green transition-colors text-sm"
                    target="_blank"
                    rel="noopener"
                  >
                    {article.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA heading="Have a Health Question?" text="Our team is always happy to answer your questions — whether you're a current patient or considering Healthy Paws for the first time." />
</BaseLayout>
