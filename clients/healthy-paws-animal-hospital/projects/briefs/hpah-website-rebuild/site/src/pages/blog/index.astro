---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTA from '../../components/CTA.astro';
import { getCollection } from 'astro:content';
import { business } from '../../data/business';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Extract unique categories from all posts
const allCategories = [...new Set(posts.flatMap((post) => post.data.categories))].sort();
---

<BaseLayout
  title="Pet Health Blog | Healthy Paws Animal Hospital"
  description="Expert pet health articles from the veterinary team at Healthy Paws Animal Hospital in Lake in the Hills, IL. Tips on wellness, dental care, senior pets, and more."
>
  <!-- Page Header -->
  <section class="bg-hpah-green-light py-12 lg:py-16">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-hpah-green font-bold text-sm uppercase tracking-wider mb-3">
          Pet Health Resources
        </p>
        <h1 class="text-4xl lg:text-5xl mb-4">Pet Health Blog</h1>
        <p class="text-lg text-hpah-text-light">
          Expert advice and tips from our veterinary team to help you keep your pets happy and healthy.
        </p>
      </div>
    </div>
  </section>

  <!-- Category Filter -->
  <section class="py-8 border-b border-gray-200">
    <div class="container">
      <div class="flex flex-wrap gap-2">
        <a
          href="/blog/"
          class="px-4 py-2 bg-hpah-green text-white text-sm font-semibold rounded-full hover:bg-hpah-green-dark transition-colors"
        >
          All Posts
        </a>
        {allCategories.map((category) => (
          <a
            href={`/blog/category/${category.toLowerCase().replace(/\s+/g, '-')}/`}
            class="px-4 py-2 bg-gray-100 text-hpah-text text-sm font-semibold rounded-full hover:bg-hpah-green-light transition-colors"
          >
            {category}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog Post Grid -->
  <section class="py-12 lg:py-16">
    <div class="container">
      {posts.length === 0 ? (
        <p class="text-center text-hpah-text-light text-lg">
          No blog posts yet. Check back soon for helpful pet health articles!
        </p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => {
            const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            });

            return (
              <article class="group bg-white rounded-lg border border-gray-200 overflow-hidden hover:shadow-lg hover:border-hpah-green transition-all">
                <!-- Image placeholder -->
                <div class="aspect-video bg-hpah-green-light flex items-center justify-center">
                  <svg class="w-12 h-12 text-hpah-green opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                  </svg>
                </div>

                <div class="p-6">
                  <!-- Category badges -->
                  {post.data.categories.length > 0 && (
                    <div class="flex flex-wrap gap-1 mb-3">
                      {post.data.categories.slice(0, 2).map((cat) => (
                        <span class="inline-block px-2 py-0.5 bg-hpah-green-light text-hpah-green text-xs font-bold uppercase tracking-wider rounded">
                          {cat}
                        </span>
                      ))}
                    </div>
                  )}

                  <h2 class="text-xl font-bold mb-2 group-hover:text-hpah-green transition-colors">
                    <a href={`/${post.id}/`} class="text-hpah-text hover:text-hpah-green">
                      {post.data.title}
                    </a>
                  </h2>

                  <p class="text-sm text-hpah-text-light mb-4 line-clamp-3">
                    {post.data.description}
                  </p>

                  <div class="flex items-center justify-between text-xs text-hpah-text-light">
                    <time datetime={post.data.date}>{formattedDate}</time>
                    <a href={`/${post.id}/`} class="text-hpah-green font-semibold hover:underline">
                      Read More &rarr;
                    </a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      )}
    </div>
  </section>

  <CTA
    heading="Have a Pet Health Question?"
    text="Our team loves helping pet owners understand their pets' health. Reach out anytime."
  />
</BaseLayout>
