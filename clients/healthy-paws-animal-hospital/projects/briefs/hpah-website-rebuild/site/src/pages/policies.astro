---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business } from '../data/business';
---

<BaseLayout
  title="Hospital Policies | Healthy Paws Animal Hospital"
  description="Review the hospital policies at Healthy Paws Animal Hospital including payment, cancellations, emergencies, vaccinations, and pet safety."
>
  <!-- Page Header -->
  <section class="bg-hpah-green-light py-16">
    <div class="container">
      <h1 class="text-4xl lg:text-5xl mb-4">Policies</h1>
    </div>
  </section>

  <!-- Policies -->
  <section class="py-16">
    <div class="container">
      <div class="max-w-3xl mx-auto prose">

        <h2>Coming Soon</h2>

      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
