---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business } from '../data/business';

import aboutHero from '../assets/images/facility/HealthyPaws-about-img.jpg';
import facilityPhoto from '../assets/images/misc/1-1.jpg';
---

<BaseLayout
  title="About Healthy Paws Animal Hospital | Lake in the Hills, IL"
  description="Learn about Healthy Paws Animal Hospital in Lake in the Hills, IL. A privately owned, full-service veterinary practice built on transparency, education, and personal care."
>
  <!-- Hero Banner -->
  <section class="hero-banner">
    <div class="absolute inset-0">
      <Image
        src={aboutHero}
        alt="The Healthy Paws Animal Hospital team"
        class="w-full h-full object-cover"
        loading="eager"
        widths={[640, 960, 1280, 1920]}
      />
      <div class="absolute inset-0" style="background: rgba(0,0,0,0.4);"></div>
    </div>
    <div class="container relative z-10 text-center">
      <h1 class="text-4xl lg:text-5xl text-white mb-4">About Healthy Paws Animal Hospital</h1>
      <p class="text-lg text-white/90 max-w-2xl mx-auto">
        Exceptional veterinary care in Lake in the Hills. Customized services, modern facilities,
        and a compassionate staff dedicated to your pet's well-being.
      </p>
    </div>
  </section>

  <!-- About Us Section (full width) -->
  <section class="py-20">
    <div class="container" style="max-width: 900px;">
      <h2 class="mb-6">About Us</h2>
      <p>
        <a href="/">Healthy Paws Animal Hospital</a> is a high-quality, full-service, state-of-the-art veterinary practice that strives to exceed every client's expectations. Our professional and courteous <a href="/meet-the-team/">staff</a> provides the best possible medical, surgical, dental, and behavioral care for clients and their cherished pets. Our commitment is to provide an exceptional veterinary experience; communication and information are our cornerstones.
      </p>
      <p>
        Services available include general <a href="/wellness-exams-lake-in-the-hills-il/">wellness exams</a>, <a href="/senior-pet-care-lake-in-the-hills-il/">senior wellness care</a>, behavioral recommendations, nutrition counseling, general and emergency <a href="/surgery/">surgery</a>, <a href="/spay-neuter-lake-in-the-hills-il/">spaying/neutering</a>, pain management, compassionate <a href="/end-of-life-care/">euthanasia services</a>, <a href="/dental-care/">digital dental radiography, and teeth cleaning</a>. Regarding vaccination, Healthy Paws embraces "one size does not fit all" and customizes protocols to each patient, following the most recent and conservative guidelines.
      </p>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- Facilities Section (2-column: image left, text right) -->
  <section class="py-20">
    <div class="container" style="max-width: 960px;">
      <div class="flex flex-col md:flex-row gap-12 items-start">
        <div class="md:w-1/3">
          <div class="divi-card">
            <Image
              src={facilityPhoto}
              alt="Dog with stethoscope at Healthy Paws Animal Hospital"
              class="w-full"
              widths={[320, 480]}
            />
          </div>
        </div>
        <div class="md:w-2/3">
          <p>
            Our hospital has an onsite laboratory, isolation ward, modern surgery suite, and comprehensive pharmacy. Features such as convenient "in-room" checkout, floor-to-ceiling exam room windows, and paperless medical records set <a href="/">Healthy Paws Animal Hospital</a> apart while providing a more relaxing, streamlined experience for pets and their owners. Details are our specialty.
          </p>
          <p class="text-hpah-text-light">
            We are conveniently located on Lakewood Road, just south of Ackman Road, in Lake in the Hills, near Crystal Lake, Huntley, Village of Lakewood, and Algonquin. <a href="/contact/">Contact us</a> today to learn more about our veterinary practice and how we can serve the needs of you and your beloved pet.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission Section (gray background) -->
  <section class="py-20" style="background-color: #DEDEE9;">
    <div class="container text-center" style="max-width: 800px;">
      <h2 class="mb-6">Our Mission</h2>
      <p class="text-lg text-hpah-text leading-relaxed" style="font-style: italic;">
        "Healthy Paws provides medically advanced, comprehensive, and compassionate <a href="/services/">veterinary care</a> in a timely and honest manner while promoting overall animal health and awareness for our clients and the community we serve."
      </p>
    </div>
  </section>

  <CTA heading="Come See the Difference for Yourself" text="Schedule a visit and discover what veterinary care looks like when it's built around your pet — not a corporate model." />
</BaseLayout>
