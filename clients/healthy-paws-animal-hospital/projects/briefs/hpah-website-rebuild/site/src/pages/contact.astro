---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business } from '../data/business';

const hours = Object.entries(business.hours).map(([day, time]) => ({
  day: day.charAt(0).toUpperCase() + day.slice(1),
  time,
}));
---

<BaseLayout
  title="Contact Us | Healthy Paws Animal Hospital"
  description={`Contact Healthy Paws Animal Hospital in Lake in the Hills, IL. Call ${business.phone} or email ${business.email}.`}
>
  <!-- Page Header -->
  <section class="bg-hpah-green-light py-16">
    <div class="container">
      <h1 class="text-4xl lg:text-5xl mb-4">Contact Us</h1>
      <p class="text-lg text-hpah-text-light max-w-2xl">
        We'd love to hear from you. Whether you need to schedule an appointment, ask a question about your pet's care,
        or just want to learn more about our practice, our team is here to help.
      </p>
    </div>
  </section>

  <!-- Contact Info + Map -->
  <section class="py-16">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Details -->
        <div>
          <h2 class="text-2xl mb-6">Get in Touch</h2>

          <div class="space-y-6">
            <!-- Phone -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-hpah-green-light rounded-full flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-hpah-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold mb-1">Phone</h3>
                <a href={`tel:${business.phoneRaw}`} class="text-hpah-blue text-lg font-semibold hover:text-hpah-green">
                  {business.phone}
                </a>
                <p class="text-sm text-hpah-text-light mt-1">
                  Calling is the fastest way to reach us and schedule an appointment.
                </p>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-hpah-green-light rounded-full flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-hpah-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold mb-1">Email</h3>
                <a href={`mailto:${business.email}`} class="text-hpah-blue text-lg font-semibold hover:text-hpah-green">
                  {business.email}
                </a>
                <p class="text-sm text-hpah-text-light mt-1">
                  For non-urgent questions, medical record requests, and general inquiries.
                </p>
              </div>
            </div>

            <!-- Address -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-hpah-green-light rounded-full flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-hpah-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold mb-1">Address</h3>
                <a
                  href={`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(business.address.full)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-hpah-blue font-semibold hover:text-hpah-green"
                >
                  {business.address.street}<br />
                  {business.address.city}, {business.address.state} {business.address.zip}
                </a>
                <p class="text-sm text-hpah-text-light mt-1">
                  Located in the Princeton Ln professional plaza, Suite 101.
                </p>
              </div>
            </div>
          </div>

          <!-- Hours Table -->
          <div class="mt-10">
            <h2 class="text-2xl mb-4">Office Hours</h2>
            <div class="bg-hpah-bg-warm rounded-lg border border-gray-200 overflow-hidden">
              <table class="w-full">
                <tbody>
                  {hours.map((row, i) => (
                    <tr class:list={[i % 2 === 0 ? 'bg-white' : 'bg-hpah-bg-warm']}>
                      <td class="px-6 py-3 font-bold">{row.day}</td>
                      <td class:list={['px-6 py-3 text-right', row.time === 'Closed' ? 'text-hpah-text-light italic' : '']}>
                        {row.time}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <p class="text-sm text-hpah-text-light mt-3">
              If your pet has an emergency outside of our business hours, please contact
              <a href="https://www.bluepearlvet.com" target="_blank" rel="noopener noreferrer" class="text-hpah-blue hover:text-hpah-green">BluePearl Emergency Pet Hospital</a>
              or your nearest 24-hour veterinary emergency clinic.
            </p>
          </div>
        </div>

        <!-- Map -->
        <div>
          <div class="rounded-lg overflow-hidden shadow-lg border border-gray-200 h-[400px] lg:h-full lg:min-h-[500px]">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2960!2d-88.3828499!3d42.2025351!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDLCsDEyJzA5LjEiTiA4OMKwMjInNTcuOSJX!5e0!3m2!1sen!2sus!4v1"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`Map showing ${business.name} location in ${business.address.city}, ${business.address.state}`}
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Driving Directions -->
  <section class="py-16 bg-hpah-bg-warm">
    <div class="container">
      <h2 class="text-2xl mb-8 text-center">Driving Directions</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="bg-white rounded-lg p-6 border border-gray-100">
          <h3 class="text-lg font-bold mb-3">From Algonquin</h3>
          <p class="text-hpah-text-light text-sm">
            Head north on Randall Rd toward Algonquin Rd. Turn left onto Princeton Ln.
            We are located in the professional plaza on the right, Suite 101. Approximately 10 minutes.
          </p>
        </div>
        <div class="bg-white rounded-lg p-6 border border-gray-100">
          <h3 class="text-lg font-bold mb-3">From Crystal Lake</h3>
          <p class="text-hpah-text-light text-sm">
            Take Rakow Rd west to Pyott Rd, then head south to Princeton Ln.
            Turn right and look for our building in the plaza on the left. Approximately 15 minutes.
          </p>
        </div>
        <div class="bg-white rounded-lg p-6 border border-gray-100">
          <h3 class="text-lg font-bold mb-3">From Huntley</h3>
          <p class="text-hpah-text-light text-sm">
            Take Route 47 south toward Lake in the Hills. Turn left onto Princeton Ln.
            Our practice is located in the professional plaza, Suite 101. Approximately 12 minutes.
          </p>
        </div>
      </div>
      <div class="text-center mt-8">
        <a
          href={`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(business.address.full)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          Get Directions on Google Maps
        </a>
      </div>
    </div>
  </section>

  <CTA heading="Have a Question?" text="Our team is happy to help. Give us a call or send us an email — we'll get back to you as quickly as we can." />
</BaseLayout>
