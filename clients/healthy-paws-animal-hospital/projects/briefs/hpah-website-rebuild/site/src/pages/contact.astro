---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business } from '../data/business';

const hours = Object.entries(business.hours).map(([day, time]) => ({
  day: day.charAt(0).toUpperCase() + day.slice(1),
  time,
}));
---

<BaseLayout
  title="Contact Us | Healthy Paws Animal Hospital"
  description={`Contact Healthy Paws Animal Hospital in Lake in the Hills, IL. Call ${business.phone} or email ${business.email}.`}
>
  <!-- Page Header -->
  <section class="bg-hpah-green-light py-16">
    <div class="container">
      <h1 class="text-4xl lg:text-5xl mb-4">Contact Healthy Paws Animal Hospital</h1>
      <p class="text-lg text-hpah-text-light max-w-2xl">
        Our <a href="/meet-the-team/" class="text-hpah-green hover:text-hpah-green">veterinary team</a> is here for you and your pet. Feel free to reach out to us at any time if you have questions.
      </p>
    </div>
  </section>

  <!-- Contact Info + Map -->
  <section class="py-16">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Details -->
        <div>
          <h2 class="text-2xl mb-6">Get in Touch</h2>

          <div class="space-y-6">
            <!-- Phone -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-hpah-green-light rounded-full flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-hpah-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold mb-1">Phone</h3>
                <a href={`tel:${business.phoneRaw}`} class="text-hpah-green text-lg font-semibold hover:text-hpah-green">
                  {business.phone}
                </a>
              </div>
            </div>

            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-hpah-green-light rounded-full flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-hpah-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold mb-1">Email</h3>
                <a href={`mailto:${business.email}`} class="text-hpah-green text-lg font-semibold hover:text-hpah-green">
                  {business.email}
                </a>
              </div>
            </div>

            <!-- Address -->
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-hpah-green-light rounded-full flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-hpah-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold mb-1">Address</h3>
                <a
                  href={`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(business.address.full)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-hpah-green font-semibold hover:text-hpah-green"
                >
                  {business.address.street}<br />
                  {business.address.city}, {business.address.state} {business.address.zip}
                </a>
              </div>
            </div>
          </div>

          <!-- Hours Table -->
          <div class="mt-10">
            <h2 class="text-2xl mb-4">Office Hours</h2>
            <div class="bg-hpah-bg-warm rounded-lg border border-gray-200 overflow-hidden">
              <table class="w-full">
                <tbody>
                  {hours.map((row, i) => (
                    <tr class:list={[i % 2 === 0 ? 'bg-white' : 'bg-hpah-bg-warm']}>
                      <td class="px-6 py-3 font-bold">{row.day}</td>
                      <td class:list={['px-6 py-3 text-right', row.time === 'Closed' ? 'text-hpah-text-light italic' : '']}>
                        {row.time}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
            <p class="text-sm text-hpah-text-light mt-3">
              When we are not in the office, <a href="https://maps.app.goo.gl/JWQpbcEoqbXDJ6ccA" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:text-hpah-green">Companion Animal Specialty and Emergency</a> (located less than ten minutes away) provides 24-hour emergency care for our clients.
            </p>
          </div>
        </div>

        <!-- Map -->
        <div>
          <div class="rounded-lg overflow-hidden shadow-lg border border-gray-200 h-[400px] lg:h-full lg:min-h-[500px]">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2960!2d-88.3828499!3d42.2025351!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDLCsDEyJzA5LjEiTiA4OMKwMjInNTcuOSJX!5e0!3m2!1sen!2sus!4v1"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`Map showing ${business.name} location in ${business.address.city}, ${business.address.state}`}
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mission Section -->
  <section class="py-16 bg-hpah-bg-warm">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl mb-6">We Proudly Serve the Pets of Lake in the Hills, IL, and Beyond</h2>
        <p class="text-hpah-text-light text-lg">
          It is our mission to partner with our clients to nurture and preserve the human-animal bond by providing compassionate, expert, and affordable <a href="/services/" class="text-hpah-green hover:text-hpah-green">veterinary care</a> from your pet's first adventure throughout a long and healthy life.
        </p>
      </div>
    </div>
  </section>

  <CTA heading="Have a Question?" text="Our team is happy to help. Give us a call or send us an email — we'll get back to you as quickly as we can." />
</BaseLayout>
