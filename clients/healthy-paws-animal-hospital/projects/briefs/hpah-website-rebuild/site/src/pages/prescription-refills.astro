---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business } from '../data/business';
---

<BaseLayout
  title="Prescription Refills | Healthy Paws Animal Hospital"
  description="Request prescription refills for your pet at Healthy Paws Animal Hospital. Call, use our app, or email. Allow 24-48 hours for processing. Lake in the Hills, IL."
>
  <!-- Page Header -->
  <section class="bg-hpah-green-light py-16 lg:py-20">
    <div class="container max-w-3xl text-center">
      <p class="text-hpah-green font-bold text-sm uppercase tracking-wider mb-4">Prescription Refills</p>
      <h1 class="text-4xl lg:text-5xl mb-6">Refilling Your Pet's Medication</h1>
      <p class="text-lg text-hpah-text-light">
        Keeping your pet on their prescribed medications is essential for their health.
        We've made the refill process as simple and convenient as possible.
      </p>
    </div>
  </section>

  <!-- How to Request -->
  <section class="py-16 lg:py-20">
    <div class="container max-w-4xl">
      <h2 class="text-3xl mb-10 text-center">Three Easy Ways to Request a Refill</h2>
      <div class="grid md:grid-cols-3 gap-8">

        <div class="bg-white rounded-lg p-8 border border-gray-100 shadow-sm text-center">
          <div class="w-14 h-14 bg-hpah-green-light rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-hpah-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Call Us</h3>
          <p class="text-hpah-text-light mb-4">
            Call our office during business hours and let our team know which medication needs to be refilled.
            We'll check your pet's records and process the request.
          </p>
          <a href={`tel:${business.phoneRaw}`} class="text-hpah-green font-semibold hover:underline">{business.phone}</a>
        </div>

        <div class="bg-white rounded-lg p-8 border border-gray-100 shadow-sm text-center">
          <div class="w-14 h-14 bg-hpah-green-light rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-hpah-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Use Our App</h3>
          <p class="text-hpah-text-light mb-4">
            The fastest way to request a refill. Open the app, select your pet's medication, and submit your
            request with a few taps. We'll notify you when it's ready.
          </p>
          <a href="/our-app/" class="text-hpah-green font-semibold hover:underline">Download the App</a>
        </div>

        <div class="bg-white rounded-lg p-8 border border-gray-100 shadow-sm text-center">
          <div class="w-14 h-14 bg-hpah-green-light rounded-lg flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-hpah-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Email Us</h3>
          <p class="text-hpah-text-light mb-4">
            Send us an email with your pet's name, the medication name, and the dosage. We'll confirm receipt
            and let you know when the refill is ready for pickup.
          </p>
          <a href={`mailto:${business.email}`} class="text-hpah-green font-semibold hover:underline">{business.email}</a>
        </div>

      </div>
    </div>
  </section>

  <!-- Processing Time -->
  <section class="py-16 bg-hpah-bg-warm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl mb-6">What to Know About Refills</h2>

      <div class="space-y-8">
        <div>
          <h3 class="text-xl font-bold mb-3 flex items-center gap-3">
            <span class="w-10 h-10 bg-hpah-green-light rounded-full flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-hpah-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </span>
            Allow 24-48 Hours for Processing
          </h3>
          <p class="text-hpah-text-light leading-relaxed">
            Please plan ahead and request your refill before you run out of medication. We need 24 to 48 business
            hours to review the prescription, verify it with your pet's records, and prepare it for pickup. Requests
            submitted over the weekend or on holidays will be processed on the next business day.
          </p>
        </div>

        <div>
          <h3 class="text-xl font-bold mb-3 flex items-center gap-3">
            <span class="w-10 h-10 bg-hpah-green-light rounded-full flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-hpah-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
              </svg>
            </span>
            When a Recheck Exam May Be Needed
          </h3>
          <p class="text-hpah-text-light leading-relaxed">
            For certain medications — particularly long-term prescriptions, controlled substances, and medications
            that affect organ function — we may require a recheck exam before approving a refill. This is to ensure
            the medication is still working as intended and your pet isn't experiencing side effects.
          </p>
          <p class="text-hpah-text-light mt-3 leading-relaxed">
            Common reasons for a recheck before refill include:
          </p>
          <ul class="space-y-2 text-hpah-text-light mt-3">
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-hpah-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              It's been more than 6-12 months since your pet's last exam
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-hpah-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              The medication requires periodic bloodwork monitoring (thyroid, kidney, liver)
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-hpah-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              Your pet's condition may have changed since the medication was originally prescribed
            </li>
            <li class="flex items-start gap-2">
              <svg class="w-5 h-5 text-hpah-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
              Illinois veterinary regulations require a current exam for the prescription
            </li>
          </ul>
          <p class="text-hpah-text-light mt-3 leading-relaxed">
            If a recheck is needed, we'll let you know promptly and help you schedule an appointment. We never
            want your pet to go without medication — if timing is tight, let us know and we'll work with you.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Online Pharmacies -->
  <section class="py-16">
    <div class="container max-w-3xl">
      <h2 class="text-3xl mb-6">Online Pharmacy Prescriptions</h2>
      <p class="text-hpah-text-light mb-6 leading-relaxed">
        We understand that some pet owners prefer to fill prescriptions through online pharmacies for convenience
        or cost reasons. We support your right to choose where you fill your pet's prescriptions and are happy
        to work with approved online pharmacies.
      </p>
      <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
        <h3 class="text-lg font-bold mb-3">How it works:</h3>
        <ol class="space-y-3 text-hpah-text-light">
          <li class="flex items-start gap-3">
            <span class="font-bold text-hpah-green">1.</span>
            The online pharmacy sends us an authorization request for your pet's prescription
          </li>
          <li class="flex items-start gap-3">
            <span class="font-bold text-hpah-green">2.</span>
            Our veterinarian reviews and approves the request (if no recheck is needed)
          </li>
          <li class="flex items-start gap-3">
            <span class="font-bold text-hpah-green">3.</span>
            We authorize the pharmacy to dispense the medication
          </li>
          <li class="flex items-start gap-3">
            <span class="font-bold text-hpah-green">4.</span>
            The medication is shipped directly to your home
          </li>
        </ol>
      </div>
      <div class="bg-amber-50 border border-amber-200 rounded-lg p-4">
        <p class="text-sm text-amber-800">
          <strong>A note about online pharmacies:</strong> We recommend using only VIPPS-accredited (Verified Internet
          Pharmacy Practice Sites) online pharmacies. Not all online pharmacies sell authentic, properly stored
          medications. If you're unsure about a pharmacy, ask us — we're happy to help you verify legitimacy.
        </p>
      </div>
    </div>
  </section>

  <!-- Quick Tips -->
  <section class="py-12 bg-hpah-green-light">
    <div class="container max-w-3xl">
      <h3 class="text-xl font-bold mb-6 text-center">Tips for Managing Your Pet's Medications</h3>
      <div class="grid sm:grid-cols-2 gap-4">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-hpah-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <p class="text-sm text-hpah-text-light">Request refills when you have a week's supply remaining — don't wait until you're out</p>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-hpah-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <p class="text-sm text-hpah-text-light">Set reminders on your phone or use our app to track medication schedules</p>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-hpah-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <p class="text-sm text-hpah-text-light">Never adjust dosage without consulting your veterinarian first</p>
        </div>
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-hpah-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <p class="text-sm text-hpah-text-light">Store medications as directed — some require refrigeration or protection from light</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Links -->
  <section class="py-12 border-t border-gray-100">
    <div class="container max-w-3xl">
      <h3 class="text-lg font-bold mb-4">Related Pages</h3>
      <div class="flex flex-wrap gap-3">
        <a href="/our-app/" class="text-hpah-green hover:underline text-sm">Our App</a>
        <span class="text-gray-300">|</span>
        <a href="/contact/" class="text-hpah-green hover:underline text-sm">Contact Us</a>
        <span class="text-gray-300">|</span>
        <a href="/policies/" class="text-hpah-green hover:underline text-sm">Hospital Policies</a>
        <span class="text-gray-300">|</span>
        <a href="/transparency-and-pricing/" class="text-hpah-green hover:underline text-sm">Transparency & Pricing</a>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
