---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business } from '../data/business';

import heroImg from '../assets/images/hero/banner-img-2.jpg';
---

<BaseLayout
  title="Local Pet Services Near Lake in the Hills, IL | Healthy Paws Animal Hospital"
  description="Recommended local pet services near Lake in the Hills, IL — trainers, adoption centers, daycare, and grooming referrals from Healthy Paws Animal Hospital."
>
  <!-- Hero Banner -->
  <section class="hero-banner">
    <div class="absolute inset-0">
      <Image
        src={heroImg}
        alt="Healthy Paws Animal Hospital"
        class="w-full h-full object-cover"
        loading="eager"
        widths={[640, 960, 1280, 1920]}
      />
      <div class="absolute inset-0" style="background: rgba(0,0,0,0.4);"></div>
    </div>
    <div class="container relative z-10 text-center">
      <h1 class="text-4xl lg:text-5xl text-white mb-4">Local Pet Services</h1>
    </div>
  </section>

  <!-- Training -->
  <section class="py-16 lg:py-20">
    <div class="container" style="max-width: 900px;">
      <h2 class="text-3xl mb-4">Training</h2>
      <p class="text-hpah-text-light mb-8">We recommend specific trainers to provide the best guidance for your pet's behavior and obedience training needs.</p>

      <div class="space-y-8 mb-16">
        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-bold mb-2">NOCI</h3>
          <p class="text-hpah-text-light">110 W Woodstock Street, Suite 2A<br/>Crystal Lake, IL 60014</p>
          <p class="mt-2">Email: <a href="mailto:NOCITHS@gmail.com" class="text-hpah-green">NOCITHS@gmail.com</a></p>
          <p>Phone: <a href="tel:847-639-3377" class="text-hpah-green font-semibold">(847) 639-3377</a> <span class="text-sm text-hpah-text-light">(voicemail only)</span></p>
          <a href="https://northwestobedienceclub.org/" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:underline text-sm mt-2 inline-block">Visit Website &rarr;</a>
        </div>

        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-bold mb-2">A Sound Beginning</h3>
          <p class="mt-2">Email: <a href="mailto:psasb22@gmail.com" class="text-hpah-green">psasb22@gmail.com</a></p>
          <p>Phone: <a href="tel:630-465-0666" class="text-hpah-green font-semibold">(630) 465-0666</a></p>
          <a href="https://www.asoundbeginningprogram.com/" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:underline text-sm mt-2 inline-block">Visit Website &rarr;</a>
        </div>
      </div>

      <div class="section-divider"></div>

      <h2 class="text-3xl mb-4 mt-16">Adoption</h2>

      <div class="space-y-8 mb-16">
        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-bold mb-2">Helping Paws</h3>
          <p class="text-hpah-text-light">2500 Harding Ln<br/>Woodstock, IL 60098</p>
          <p class="mt-2">Phone: <a href="tel:815-338-4400" class="text-hpah-green font-semibold">(815) 338-4400</a></p>
          <a href="https://helpingpaws.net/" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:underline text-sm mt-2 inline-block">Visit Website &rarr;</a>
        </div>

        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-bold mb-2">Mchenry County Animal Control</h3>
          <p class="text-hpah-text-light">100 N. Virginia Street<br/>Crystal Lake, IL 60014</p>
          <p class="mt-2">Phone: <a href="tel:815-459-6222" class="text-hpah-green font-semibold">(815) 459-6222</a></p>
          <a href="https://www.mchenrycountyil.gov/departments/health-department/veterinary-division-animal-control/adoptable-pets" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:underline text-sm mt-2 inline-block">Visit Website &rarr;</a>
        </div>
      </div>

      <div class="section-divider"></div>

      <h2 class="text-3xl mb-4 mt-16">Daycare and Boarding</h2>
      <p class="text-hpah-text-light mb-16">
        We would be happy to provide personalized daycare and boarding recommendations tailored to the unique needs of you and your pet. Please contact our team for more information and guidance.
      </p>

      <div class="section-divider"></div>

      <h2 class="text-3xl mb-4 mt-16">Grooming</h2>
      <p class="text-hpah-text-light">
        While we do not provide grooming, we are happy to recommend local groomers for your pet. Please contact our team for more information and guidance.
      </p>
    </div>
  </section>

  <CTA heading="Need a Recommendation?" text="Contact our team and we'll be happy to point you in the right direction for your pet's needs." />
</BaseLayout>
