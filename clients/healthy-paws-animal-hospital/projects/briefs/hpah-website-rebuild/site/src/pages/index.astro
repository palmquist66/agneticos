---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import { business } from '../data/business';

// Hero slider images
import heroSlide1 from '../assets/images/wp-import/a-person-with-two-dogs.jpg';
import heroSlide2 from '../assets/images/wp-import/book-app-image.jpg';
import heroSlide3 from '../assets/images/wp-import/Healthy-Paws-Office-Front-Offset.jpg';

// Service photos from WP home page
import generalCareImg from '../assets/images/wp-import/General-Care.png';
import seniorCareImg from '../assets/images/wp-import/senior-care-1.png';
import endOfLifeImg from '../assets/images/wp-import/senior-wellness.png';

// Commitment photos (WP home page)
import transparencyImg from '../assets/images/wp-import/1.jpg';
import experienceImg from '../assets/images/wp-import/3.jpg';
import teamImg from '../assets/images/wp-import/2.jpg';
import educationCommitImg from '../assets/images/wp-import/4.jpg';

const slides = [
  {
    image: heroSlide1,
    alt: 'A person with two dogs at Healthy Paws Animal Hospital',
    heading: 'Proud to be Privately Owned',
    subheading: 'Every decision is made with your pet in mind — not a corporate playbook.',
  },
  {
    image: heroSlide2,
    alt: 'Book an appointment at Healthy Paws Animal Hospital',
    heading: 'Come Experience Veterinary Medicine in a Whole New Way',
    subheading: 'Transparent, educational, and compassionate care for your pet.',
  },
  {
    image: heroSlide3,
    alt: 'Healthy Paws Animal Hospital building exterior',
    heading: 'Healthy Paws Animal Hospital',
    subheading: 'Lake in the Hills, IL — serving pets and their families since 2010.',
  },
];

const commitments = [
  {
    title: 'Transparency',
    subtitle: 'Clear and Kind',
    description: 'This is the single word that has guided our practice since day one. As a team, we are committed to being vulnerable, telling and showing what we do honestly, allowing us to create trusting relationships with both our clients and their pets.',
    href: '/transparency/',
    image: transparencyImg,
  },
  {
    title: "Your Pet's Experience",
    subtitle: 'Your Experience',
    description: 'How would I like to be treated if I were taking my sick pet to the veterinarian? When building our practice, we challenged traditional veterinary office ideas to create a better experience for our clients and patients.',
    href: '/your-pets-experience/',
    image: experienceImg,
  },
  {
    title: 'Our Team',
    subtitle: 'Our Secret Sauce',
    description: 'Our team is, hands down, what makes us different. They are the salt of the Earth, talented and confident in what they do and do not know. Striving to exceed expectations is our guiding principle.',
    href: '/meet-the-team/',
    image: teamImg,
  },
  {
    title: 'Education',
    subtitle: 'Where Trust Begins',
    description: 'The gift of education is one that keeps on giving. We want our pet owners to feel like partners with us in making the best decisions for their pets. This can only be successful if we do our part by educating our clients first.',
    href: '/education/',
    image: educationCommitImg,
  },
];

// Real Google reviews as shown on the WP home page
const testimonials = [
  {
    text: 'The Healthy Paws team is kind and compassionate. Dr. Burgess is attentive and provides a level of comfort that I trust fully to care for my furr babies. Thank you for all you do!',
    author: 'Kate W.',
    rating: 5,
  },
  {
    text: 'We love the professional and personal feel of this office! I always recommend Healthy Paws to friends and family!',
    author: 'Jennifer G.',
    rating: 5,
  },
  {
    text: 'Love Healthy Paws!! Easy to schedule an appointment, staff and Drs are friendly, helpful and supportive. Harley is a handful, but they take great care of him. Totally recommend. Have been a "patient" since they first opened their door',
    author: 'Lynn P.',
    rating: 5,
  },
  {
    text: 'Amazing staff and they got my dog in immediately as a new client. The Dr was very thorough and the entire staff was on top of everything & detail oriented. I highly recommend. I actually am switching my dog to this vet because I was so happy with everything and everyone.',
    author: 'Kari B.',
    rating: 5,
  },
  {
    text: 'All the staff was wonderful from the front desk, to the tech and the doctor!!! Highly recommend!!!',
    author: 'Beth S.',
    rating: 5,
  },
];
---

<BaseLayout
  title="Veterinarian in Lake in the Hills, IL | Healthy Paws Animal Hospital"
  description="Healthy Paws Animal Hospital — a privately owned veterinary practice in Lake in the Hills, IL dedicated to gentle, low-stress care. Transparency, education, and compassion. Call (815) 322-5400."
>
  <!-- Hero Slider -->
  <section class="hero-slider relative" style="min-height: 550px;" aria-label="Featured slides">
    {slides.map((slide, i) => (
      <div
        class:list={['hero-slide', i === 0 ? 'active' : '']}
        data-slide-index={i}
      >
        <div class="relative" style="min-height: 550px;">
          <Image
            src={slide.image}
            alt={slide.alt}
            class="absolute inset-0 w-full h-full object-cover"
            loading={i === 0 ? 'eager' : 'lazy'}
            widths={[640, 960, 1280, 1920]}
          />
          <div class="absolute inset-0" style="background: rgba(0,0,0,0.55);"></div>
          <div class="relative z-10 flex items-center justify-center text-center" style="min-height: 550px; padding: 4rem 1.5rem;">
            <div class="max-w-3xl">
              <h2 class="text-4xl lg:text-5xl text-white mb-4" style="font-family: var(--font-narrow);">
                {slide.heading}
              </h2>
              <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
                {slide.subheading}
              </p>
              <a href="/schedule/" class="btn-primary text-lg">
                Schedule an Appointment
              </a>
            </div>
          </div>
        </div>
      </div>
    ))}
    <!-- Slider dots -->
    <div class="absolute bottom-6 left-0 right-0 z-20 flex justify-center gap-3">
      {slides.map((_, i) => (
        <button
          class:list={['w-3 h-3 rounded-full transition-all', i === 0 ? 'bg-white' : 'bg-white/50']}
          data-dot-index={i}
          aria-label={`Go to slide ${i + 1}`}
        />
      ))}
    </div>
  </section>

  <!-- Alert Bar -->
  <div class="alert-bar">
    <div class="container">
      <p class="mb-0"><strong>Holiday Notice:</strong> Please call for current holiday hours. We appreciate your understanding.</p>
    </div>
  </div>

  <!-- Services Section (3-column blurbs matching WP) -->
  <section class="py-20">
    <div class="container">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2>Exceptional Veterinary Care for Every Stage of Life</h2>
        <p class="text-hpah-text-light mt-4 italic">
          Professional. Educational. Personal.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <a href="/general-care-lake-in-the-hills-il/" class="group text-center">
          <div class="mb-5 overflow-hidden rounded-lg">
            <Image src={generalCareImg} alt="General veterinary care" width={500} height={500} class="w-full aspect-square object-cover transition-transform duration-300 group-hover:scale-105" />
          </div>
          <h3 class="text-xl font-bold mb-2 group-hover:text-hpah-green transition-colors">General Care</h3>
          <p class="text-hpah-text-light text-base">Healthy beginnings for a lifetime of care</p>
        </a>
        <a href="/senior-pet-care-lake-in-the-hills-il/" class="group text-center">
          <div class="mb-5 overflow-hidden rounded-lg">
            <Image src={seniorCareImg} alt="Senior pet care" width={500} height={500} class="w-full aspect-square object-cover transition-transform duration-300 group-hover:scale-105" />
          </div>
          <h3 class="text-xl font-bold mb-2 group-hover:text-hpah-green transition-colors">Senior Care</h3>
          <p class="text-hpah-text-light text-base">Helping your pet thrive in every chapter</p>
        </a>
        <a href="/end-of-life-care/" class="group text-center">
          <div class="mb-5 overflow-hidden rounded-lg">
            <Image src={endOfLifeImg} alt="End of life care" width={500} height={500} class="w-full aspect-square object-cover transition-transform duration-300 group-hover:scale-105" />
          </div>
          <h3 class="text-xl font-bold mb-2 group-hover:text-hpah-green transition-colors">End of Life Care</h3>
          <p class="text-hpah-text-light text-base">Compassion and comfort when you need it most</p>
        </a>
      </div>
      <div class="text-center mt-10">
        <a href="/services/" class="btn-primary">
          View All Services
        </a>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- Commitment Section (4-column grid matching WP) -->
  <section class="py-20" style="background: rgba(72,170,67,0.16);">
    <div class="container">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2>Our Commitment to You and Your Pet&hellip;</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-8">
        {commitments.map((item) => (
          <a href={item.href} class="group block text-center">
            <div class="mb-5 overflow-hidden rounded-lg">
              <Image src={item.image} alt={item.title} widths={[300, 450, 600]} class="w-full aspect-[4/3] object-cover transition-transform duration-300 group-hover:scale-105" />
            </div>
            <h3 class="text-lg font-bold mb-3 text-hpah-text group-hover:text-hpah-green transition-colors">{item.title}&hellip;{item.subtitle}</h3>
            <p class="text-hpah-text-light text-sm mb-0">{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Veterinary Care band -->
  <section class="py-16" style="background: rgba(72,170,67,0.16);">
    <div class="container text-center max-w-3xl mx-auto">
      <h2 class="mb-4">Veterinary Care in Lake in the Hills, IL</h2>
      <p class="text-hpah-text-light mb-8">
        At Healthy Paws Animal Hospital, we take pride in offering a comprehensive range of veterinary services to cater to all your pet's needs.
      </p>
      <a href="/services/" class="btn-primary">View All Services</a>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2>Thank You for Your Kind Words</h2>
      </div>
      <!-- Testimonial Carousel -->
      <div class="relative overflow-hidden" id="testimonial-carousel">
        <div class="flex transition-transform duration-500" id="testimonial-track">
          {testimonials.map((review, i) => (
            <div class="w-full md:w-1/3 flex-shrink-0 px-4" data-testimonial={i}>
              <div class="bg-hpah-green-light rounded-lg p-8 h-full flex flex-col">
                <div class="flex gap-1 mb-4">
                  {Array.from({ length: review.rating }).map(() => (
                    <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
                <blockquote class="text-hpah-text mb-4 italic flex-1">
                  "{review.text}"
                </blockquote>
                <p class="text-sm font-semibold text-hpah-text-light">— {review.author}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="text-center mt-10">
        <a
          href={business.social.google}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          Read More Reviews
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  // Hero slider
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('[data-dot-index]');
  let currentSlide = 0;
  const slideCount = slides.length;

  function goToSlide(index: number) {
    slides[currentSlide].classList.remove('active');
    dots[currentSlide].classList.remove('bg-white');
    dots[currentSlide].classList.add('bg-white/50');

    currentSlide = index;

    slides[currentSlide].classList.add('active');
    dots[currentSlide].classList.remove('bg-white/50');
    dots[currentSlide].classList.add('bg-white');
  }

  // Auto-advance every 8 seconds (matching WP site)
  let timer = setInterval(() => {
    goToSlide((currentSlide + 1) % slideCount);
  }, 8000);

  // Dot click handlers
  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const index = parseInt(dot.getAttribute('data-dot-index') || '0');
      goToSlide(index);
      clearInterval(timer);
      timer = setInterval(() => {
        goToSlide((currentSlide + 1) % slideCount);
      }, 8000);
    });
  });
</script>
