---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business, services } from '../data/business';

// Hero slider images
import heroSlide1 from '../assets/images/wp-import/a-person-with-two-dogs.jpg';
import heroSlide2 from '../assets/images/wp-import/book-app-image.jpg';
import heroSlide3 from '../assets/images/wp-import/Healthy-Paws-Office-Front-Offset.jpg';

// Service icons from WP
import generalCareIcon from '../assets/images/wp-import/General-Care.png';
import seniorCareIcon from '../assets/images/wp-import/Senior-Care.png';

const slides = [
  {
    image: heroSlide1,
    alt: 'A person with two dogs at Healthy Paws Animal Hospital',
    heading: 'Proud to be Privately Owned',
    subheading: 'Every decision is made with your pet in mind — not a corporate playbook.',
  },
  {
    image: heroSlide2,
    alt: 'Book an appointment at Healthy Paws Animal Hospital',
    heading: 'Come Experience Veterinary Medicine in a Whole New Way',
    subheading: 'Transparent, educational, and compassionate care for your pet.',
  },
  {
    image: heroSlide3,
    alt: 'Healthy Paws Animal Hospital building exterior',
    heading: 'Healthy Paws Animal Hospital',
    subheading: 'Lake in the Hills, IL — serving pets and their families since 2010.',
  },
];

const commitments = [
  {
    title: 'Transparency',
    subtitle: 'Clear and Kind',
    description: 'From the very beginning, one powerful term has steered our approach. We remain dedicated to transparently showcasing our actions.',
    href: '/transparency-and-pricing/',
  },
  {
    title: "Your Pet's Experience",
    subtitle: 'Your Experience',
    description: 'We aimed to innovate and elevate, crafting an enhanced experience for both our clients and their beloved animal companions.',
    href: '/your-pets-experience/',
  },
  {
    title: 'Our Team',
    subtitle: 'Our Secret Sauce',
    description: 'Undoubtedly, our team sets us apart. Comprising individuals who embody a down-to-earth ethos and showcase remarkable talents.',
    href: '/meet-the-team/',
  },
  {
    title: 'Education',
    subtitle: 'Where Trust Begins',
    description: 'We aim for pet owners to perceive themselves as collaborative partners in making optimal choices for their pets.',
    href: '/info-center/',
  },
];

const testimonials = [
  {
    text: 'The care our pets receive at Healthy Paws is unmatched. Dr. Burgess and the entire team take the time to explain everything and truly care about our animals.',
    author: 'Lake in the Hills Pet Owner',
    rating: 5,
  },
  {
    text: 'We switched from a corporate vet to Healthy Paws and the difference is night and day. The gentle, low-stress approach makes all the difference — our cat actually doesn\'t mind going to the vet anymore.',
    author: 'Crystal Lake Pet Owner',
    rating: 5,
  },
  {
    text: 'The transparency and education we receive is incredible. They never push unnecessary treatments and always explain their recommendations thoroughly.',
    author: 'Algonquin Pet Owner',
    rating: 5,
  },
  {
    text: 'Dr. Burgess personally called to check on our dog after surgery. You don\'t get that kind of follow-up anywhere else. This is what veterinary care should be.',
    author: 'Huntley Pet Owner',
    rating: 5,
  },
  {
    text: 'From the moment you walk in, you can tell this is a different kind of vet. The team genuinely loves what they do, and it shows in how they treat every patient.',
    author: 'Cary Pet Owner',
    rating: 5,
  },
];
---

<BaseLayout
  title="Veterinarian in Lake in the Hills, IL | Healthy Paws Animal Hospital"
  description="Healthy Paws Animal Hospital — a privately owned veterinary practice in Lake in the Hills, IL dedicated to gentle, low-stress care. Transparency, education, and compassion. Call (815) 322-5400."
>
  <!-- Hero Slider -->
  <section class="hero-slider relative" style="min-height: 550px;" aria-label="Featured slides">
    {slides.map((slide, i) => (
      <div
        class:list={['hero-slide', i === 0 ? 'active' : '']}
        data-slide-index={i}
      >
        <div class="relative" style="min-height: 550px;">
          <Image
            src={slide.image}
            alt={slide.alt}
            class="absolute inset-0 w-full h-full object-cover"
            loading={i === 0 ? 'eager' : 'lazy'}
            widths={[640, 960, 1280, 1920]}
          />
          <div class="absolute inset-0" style="background: rgba(0,0,0,0.55);"></div>
          <div class="relative z-10 flex items-center justify-center text-center" style="min-height: 550px; padding: 4rem 1.5rem;">
            <div class="max-w-3xl">
              <h2 class="text-4xl lg:text-5xl text-white mb-4" style="font-family: var(--font-narrow);">
                {slide.heading}
              </h2>
              <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">
                {slide.subheading}
              </p>
              <a href="/schedule/" class="btn-primary text-lg">
                Schedule an Appointment
              </a>
            </div>
          </div>
        </div>
      </div>
    ))}
    <!-- Slider dots -->
    <div class="absolute bottom-6 left-0 right-0 z-20 flex justify-center gap-3">
      {slides.map((_, i) => (
        <button
          class:list={['w-3 h-3 rounded-full transition-all', i === 0 ? 'bg-white' : 'bg-white/50']}
          data-dot-index={i}
          aria-label={`Go to slide ${i + 1}`}
        />
      ))}
    </div>
  </section>

  <!-- Alert Bar -->
  <div class="alert-bar">
    <div class="container">
      <p class="mb-0"><strong>Holiday Notice:</strong> Please call for current holiday hours. We appreciate your understanding.</p>
    </div>
  </div>

  <!-- Services Section (3-column blurbs matching WP) -->
  <section class="py-20">
    <div class="container">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2>Comprehensive Veterinary Services</h2>
        <p class="text-hpah-text-light mt-4">
          From wellness exams and preventive care to surgery and end-of-life support, we provide compassionate, comprehensive veterinary services for every stage of your pet's life.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <a href="/services/" class="group text-center">
          <div class="mb-4 flex justify-center">
            <Image src={generalCareIcon} alt="General veterinary care" width={80} height={80} />
          </div>
          <h3 class="text-xl font-bold mb-2 group-hover:text-hpah-green transition-colors">General Care</h3>
          <p class="text-hpah-text-light text-base">Wellness exams, vaccinations, nutrition counseling, and preventive care for pets of all ages.</p>
        </a>
        <a href="/senior-pet-care-lake-in-the-hills-il/" class="group text-center">
          <div class="mb-4 flex justify-center">
            <Image src={seniorCareIcon} alt="Senior pet care" width={80} height={80} />
          </div>
          <h3 class="text-xl font-bold mb-2 group-hover:text-hpah-green transition-colors">Senior Care</h3>
          <p class="text-hpah-text-light text-base">Specialized care for pets aged 8+, including proactive health monitoring and lab work.</p>
        </a>
        <a href="/services/" class="group text-center">
          <div class="mb-4 flex justify-center">
            <svg class="w-20 h-20 text-hpah-green" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2 group-hover:text-hpah-green transition-colors">End of Life Care</h3>
          <p class="text-hpah-text-light text-base">Compassionate euthanasia services in a quiet, private space, ensuring a peaceful passing.</p>
        </a>
      </div>
      <div class="text-center mt-10">
        <a href="/services/" class="btn-primary">
          View All Services
        </a>
      </div>
    </div>
  </section>

  <div class="section-divider"></div>

  <!-- Commitment Section (4-column grid matching WP) -->
  <section class="py-20" style="background: rgba(72,170,67,0.16);">
    <div class="container">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2>What Sets Us Apart</h2>
        <p class="text-hpah-text-light mt-4">
          From the very beginning, these values have guided everything we do.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {commitments.map((item) => (
          <a href={item.href} class="group bg-white rounded-lg p-8 border border-hpah-gray hover:shadow-lg transition-all text-center">
            <h3 class="text-xl font-bold mb-1 group-hover:text-hpah-green transition-colors">{item.title}</h3>
            <p class="text-hpah-green-accent font-bold text-sm mb-3" style="color: var(--color-hpah-green-accent);">{item.subtitle}</p>
            <p class="text-hpah-text-light text-sm mb-0">{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 bg-white">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2>What Pet Owners Are Saying</h2>
        <p class="text-hpah-text-light mt-4">
          Don't take our word for it — hear from the pet owners who trust us with their family members.
        </p>
      </div>
      <!-- Testimonial Carousel -->
      <div class="relative overflow-hidden" id="testimonial-carousel">
        <div class="flex transition-transform duration-500" id="testimonial-track">
          {testimonials.map((review, i) => (
            <div class="w-full md:w-1/3 flex-shrink-0 px-4" data-testimonial={i}>
              <div class="bg-hpah-green-light rounded-lg p-8 h-full flex flex-col">
                <div class="flex gap-1 mb-4">
                  {Array.from({ length: review.rating }).map(() => (
                    <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
                <blockquote class="text-hpah-text mb-4 italic flex-1">
                  "{review.text}"
                </blockquote>
                <p class="text-sm font-semibold text-hpah-text-light">— {review.author}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="text-center mt-10">
        <a
          href={business.social.google}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-secondary"
        >
          Read More Reviews
        </a>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-16 bg-white border-t border-hpah-gray">
    <div class="container text-center">
      <h2 class="mb-4">Proudly Serving McHenry & Kane County Communities</h2>
      <p class="text-hpah-text-light mb-8 max-w-2xl mx-auto">
        Located in Lake in the Hills, we welcome pets and their families from across the region.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        {[
          { name: 'Lake in the Hills', href: '/areas-we-serve/' },
          { name: 'Algonquin', href: '/veterinarian-algonquin-il/' },
          { name: 'Huntley', href: '/veterinarian-huntley-il/' },
          { name: 'Crystal Lake', href: '/veterinarian-crystal-lake-il/' },
          { name: 'Cary', href: '/areas-we-serve/' },
          { name: 'Village of Lakewood', href: '/areas-we-serve/' },
        ].map((area) => (
          <a
            href={area.href}
            class="px-6 py-3 bg-hpah-green-light rounded-full text-hpah-text font-semibold hover:bg-hpah-green hover:text-white transition-colors"
          >
            {area.name}, IL
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>

<script>
  // Hero slider
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('[data-dot-index]');
  let currentSlide = 0;
  const slideCount = slides.length;

  function goToSlide(index: number) {
    slides[currentSlide].classList.remove('active');
    dots[currentSlide].classList.remove('bg-white');
    dots[currentSlide].classList.add('bg-white/50');

    currentSlide = index;

    slides[currentSlide].classList.add('active');
    dots[currentSlide].classList.remove('bg-white/50');
    dots[currentSlide].classList.add('bg-white');
  }

  // Auto-advance every 8 seconds (matching WP site)
  let timer = setInterval(() => {
    goToSlide((currentSlide + 1) % slideCount);
  }, 8000);

  // Dot click handlers
  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const index = parseInt(dot.getAttribute('data-dot-index') || '0');
      goToSlide(index);
      clearInterval(timer);
      timer = setInterval(() => {
        goToSlide((currentSlide + 1) % slideCount);
      }, 8000);
    });
  });
</script>
