---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business, services } from '../data/business';

const featuredServices = services.slice(0, 8);

const differentiators = [
  {
    title: 'Gentle, Low-Stress Care',
    description: 'Our entire team is trained in gentle handling to reduce fear, anxiety, and stress during every visit. Your pet\'s comfort is never an afterthought.',
    icon: '💚',
  },
  {
    title: 'Privately Owned',
    description: 'No corporate playbook. Every decision is made with your pet\'s best interest in mind — not a shareholder\'s.',
    icon: '🏠',
  },
  {
    title: 'Education First',
    description: 'We take the time to explain the "why" behind every recommendation. Informed pet owners make the best decisions.',
    icon: '📚',
  },
  {
    title: 'Transparency',
    description: 'From pricing to treatment plans, we believe you deserve to know exactly what\'s happening and why. No surprises.',
    icon: '🔍',
  },
  {
    title: 'Single Exam Room Design',
    description: 'Your pet goes directly to the exam room — no crowded lobby, no anxious waiting. We consider it a failure if you spend time in ours.',
    icon: '🚪',
  },
  {
    title: 'Personal Follow-Up',
    description: 'After surgery and significant procedures, Dr. Burgess personally follows up to check on your pet\'s recovery.',
    icon: '📞',
  },
];

const testimonials = [
  {
    text: 'The care our pets receive at Healthy Paws is unmatched. Dr. Burgess and the entire team take the time to explain everything and truly care about our animals.',
    author: 'Lake in the Hills Pet Owner',
    rating: 5,
  },
  {
    text: 'We switched from a corporate vet to Healthy Paws and the difference is night and day. The gentle, low-stress approach makes all the difference — our cat actually doesn\'t mind going to the vet anymore.',
    author: 'Crystal Lake Pet Owner',
    rating: 5,
  },
  {
    text: 'The transparency and education we receive is incredible. They never push unnecessary treatments and always explain their recommendations thoroughly.',
    author: 'Algonquin Pet Owner',
    rating: 5,
  },
];
---

<BaseLayout
  title="Veterinarian in Lake in the Hills, IL | Healthy Paws Animal Hospital"
  description="Healthy Paws Animal Hospital — a privately owned veterinary practice in Lake in the Hills, IL dedicated to gentle, low-stress care. Personal. Professional. Educational. Call (815) 322-5400."
>
  <!-- Hero -->
  <section class="relative bg-hpah-green-light overflow-hidden">
    <div class="container py-20 lg:py-28">
      <div class="max-w-2xl">
        <p class="text-hpah-green font-bold text-sm uppercase tracking-wider mb-4">
          Gentle, Low-Stress Care &bull; Privately Owned &bull; Women-Owned
        </p>
        <h1 class="text-4xl lg:text-5xl mb-6 leading-tight">
          Come Experience Veterinary Medicine in a Whole New Way
        </h1>
        <p class="text-lg text-hpah-text-light mb-8 max-w-xl">
          Healthy Paws Animal Hospital is a privately owned veterinary practice in Lake in the Hills, IL.
          We believe in transparency, education, and treating every pet like family. Details are our specialty.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/schedule/" class="btn-primary text-lg">
            Schedule a Visit
          </a>
          <a href={`tel:${business.phoneRaw}`} class="btn-secondary text-lg">
            Call {business.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-20">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2>Comprehensive Veterinary Services</h2>
        <p class="text-hpah-text-light mt-4">
          From wellness exams to specialized care, we provide everything your pet needs under one roof.
          Each service is delivered with our gentle, low-stress approach and a commitment to education.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {featuredServices.map((service) => (
          <a
            href={`/${service.slug}/`}
            class="group block bg-white rounded-lg border border-gray-200 p-6 hover:border-hpah-green hover:shadow-lg transition-all"
          >
            <span class="text-3xl mb-3 block">{service.icon}</span>
            <h3 class="text-lg font-bold mb-2 group-hover:text-hpah-green transition-colors">{service.name}</h3>
            <p class="text-sm text-hpah-text-light">{service.description}</p>
          </a>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/services/" class="btn-secondary">
          View All Services &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="py-20 bg-hpah-bg-warm">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2>Why Pet Owners Choose Healthy Paws</h2>
        <p class="text-hpah-text-light mt-4">
          We built the practice we always wished existed. Here's what makes us different.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {differentiators.map((item) => (
          <div class="bg-white rounded-lg p-8 border border-gray-100">
            <span class="text-3xl mb-4 block">{item.icon}</span>
            <h3 class="text-xl font-bold mb-3">{item.title}</h3>
            <p class="text-hpah-text-light">{item.description}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/why-choose-us/" class="btn-primary">
          Learn More About Our Approach
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2>What Pet Owners Are Saying</h2>
        <p class="text-hpah-text-light mt-4">
          Don't take our word for it — hear from the pet owners who trust us with their family members.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {testimonials.map((review) => (
          <div class="bg-hpah-green-light rounded-lg p-8">
            <div class="flex gap-1 mb-4">
              {Array.from({ length: review.rating }).map(() => (
                <svg class="w-5 h-5 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="text-hpah-text mb-4 italic">
              "{review.text}"
            </blockquote>
            <p class="text-sm font-semibold text-hpah-text-light">— {review.author}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/reviews/" class="btn-secondary">
          Read More Reviews
        </a>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="py-16 bg-white">
    <div class="container text-center">
      <h2 class="mb-4">Proudly Serving McHenry & Kane County Communities</h2>
      <p class="text-hpah-text-light mb-8 max-w-2xl mx-auto">
        Located in Lake in the Hills, we welcome pets and their families from across the region.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        {[
          { name: 'Lake in the Hills', href: '/areas-we-serve/' },
          { name: 'Algonquin', href: '/veterinarian-algonquin-il/' },
          { name: 'Huntley', href: '/veterinarian-huntley-il/' },
          { name: 'Crystal Lake', href: '/veterinarian-crystal-lake-il/' },
          { name: 'Cary', href: '/areas-we-serve/' },
          { name: 'Village of Lakewood', href: '/areas-we-serve/' },
        ].map((area) => (
          <a
            href={area.href}
            class="px-6 py-3 bg-hpah-green-light rounded-full text-hpah-text font-semibold hover:bg-hpah-green hover:text-white transition-colors"
          >
            {area.name}, IL
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
