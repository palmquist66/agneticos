---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business } from '../data/business';
---

<BaseLayout
  title="Our App | Healthy Paws Animal Hospital"
  description="Download the Healthy Paws Animal Hospital app for appointment reminders, prescription refill requests, pet health records, and two-way messaging with our team."
>
  <!-- Page Header -->
  <section class="bg-hpah-green-light py-16 lg:py-20">
    <div class="container max-w-3xl text-center">
      <p class="text-hpah-green font-bold text-sm uppercase tracking-wider mb-4">Our App</p>
      <h1 class="text-4xl lg:text-5xl mb-6">Your Pet's Health at Your Fingertips</h1>
      <p class="text-lg text-hpah-text-light">
        Manage appointments, request prescription refills, access your pet's health records, and message
        our team — all from your phone. The Healthy Paws app makes caring for your pet even easier.
      </p>
    </div>
  </section>

  <!-- App Benefits -->
  <section class="py-16 lg:py-20">
    <div class="container max-w-4xl">
      <h2 class="text-3xl mb-10 text-center">What You Can Do With the App</h2>
      <div class="grid md:grid-cols-2 gap-8">

        <div class="bg-white rounded-lg p-8 border border-gray-100 shadow-sm">
          <div class="w-12 h-12 bg-hpah-green-light rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-hpah-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Appointment Reminders</h3>
          <p class="text-hpah-text-light">
            Never miss a wellness exam, vaccine booster, or follow-up appointment. The app sends push notifications
            and reminders so you always know when your pet's next visit is due. You can also request appointments
            directly from the app.
          </p>
        </div>

        <div class="bg-white rounded-lg p-8 border border-gray-100 shadow-sm">
          <div class="w-12 h-12 bg-hpah-green-light rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-hpah-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Prescription Refill Requests</h3>
          <p class="text-hpah-text-light">
            Running low on your pet's medication? Request refills through the app with a few taps. Our pharmacy
            team will prepare your order, and we'll notify you when it's ready for pickup. No phone calls needed.
          </p>
        </div>

        <div class="bg-white rounded-lg p-8 border border-gray-100 shadow-sm">
          <div class="w-12 h-12 bg-hpah-green-light rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-hpah-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Pet Health Records</h3>
          <p class="text-hpah-text-light">
            Access your pet's vaccination history, lab results, treatment summaries, and weight records anytime.
            This is especially helpful when boarding, traveling, or if you ever need to share records with another
            veterinary facility.
          </p>
        </div>

        <div class="bg-white rounded-lg p-8 border border-gray-100 shadow-sm">
          <div class="w-12 h-12 bg-hpah-green-light rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-hpah-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">Two-Way Messaging</h3>
          <p class="text-hpah-text-light">
            Have a quick question that doesn't need a phone call? Message our team directly through the app.
            Whether it's a question about medication dosing, a follow-up concern, or scheduling, you'll get a
            response during business hours without sitting on hold.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Additional Features -->
  <section class="py-16 bg-hpah-bg-warm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl mb-8">Additional Features</h2>
      <div class="space-y-4">
        <div class="flex items-start gap-4">
          <svg class="w-6 h-6 text-hpah-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="font-semibold text-hpah-text">Loyalty Rewards</p>
            <p class="text-hpah-text-light">Earn points with every visit that can be redeemed toward future services</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <svg class="w-6 h-6 text-hpah-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="font-semibold text-hpah-text">Multiple Pet Profiles</p>
            <p class="text-hpah-text-light">Manage all your pets in one place with separate health timelines for each</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <svg class="w-6 h-6 text-hpah-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="font-semibold text-hpah-text">Vaccination Due Date Alerts</p>
            <p class="text-hpah-text-light">Automatic notifications when vaccines or preventive treatments are coming due</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <svg class="w-6 h-6 text-hpah-green shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <div>
            <p class="font-semibold text-hpah-text">Food & Medication Reminders</p>
            <p class="text-hpah-text-light">Set custom reminders for daily medications, flea/tick treatments, or feeding schedules</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Download Section -->
  <section class="py-16 lg:py-20">
    <div class="container max-w-3xl text-center">
      <h2 class="text-3xl mb-4">Download the App</h2>
      <p class="text-hpah-text-light mb-8">
        Available for free on iPhone and Android. Download today to get started — then link your account
        using the email address we have on file for you.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <!-- Apple App Store Button -->
        <a
          href="#"
          class="inline-flex items-center gap-3 bg-black text-white px-6 py-3 rounded-lg hover:bg-gray-800 transition-colors"
          aria-label="Download on the App Store"
        >
          <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
          </svg>
          <div class="text-left">
            <p class="text-xs">Download on the</p>
            <p class="text-lg font-semibold -mt-1">App Store</p>
          </div>
        </a>

        <!-- Google Play Button -->
        <a
          href="#"
          class="inline-flex items-center gap-3 bg-black text-white px-6 py-3 rounded-lg hover:bg-gray-800 transition-colors"
          aria-label="Get it on Google Play"
        >
          <svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor">
            <path d="M3 20.5v-17c0-.59.34-1.11.84-1.35L13.69 12l-9.85 9.85c-.5-.24-.84-.76-.84-1.35zm13.81-5.38L6.05 21.34l8.49-8.49 2.27 2.27zm.91-.91L19.59 12l-1.87-2.21-2.27 2.27 2.27 2.15zM6.05 2.66l10.76 6.22-2.27 2.27-8.49-8.49z"/>
          </svg>
          <div class="text-left">
            <p class="text-xs">GET IT ON</p>
            <p class="text-lg font-semibold -mt-1">Google Play</p>
          </div>
        </a>
      </div>
      <p class="text-sm text-hpah-text-light mt-6">
        Need help setting up the app? Call us at <a href={`tel:${business.phoneRaw}`} class="text-hpah-green hover:underline">{business.phone}</a>
        and our team will walk you through it.
      </p>
    </div>
  </section>

  <!-- Getting Started -->
  <section class="py-16 bg-hpah-bg-warm">
    <div class="container max-w-3xl">
      <h2 class="text-3xl mb-8 text-center">Getting Started</h2>
      <div class="space-y-6">
        <div class="flex items-start gap-4">
          <div class="w-8 h-8 bg-hpah-green text-white rounded-full flex items-center justify-center font-bold shrink-0">1</div>
          <div>
            <p class="font-semibold text-hpah-text">Download the app</p>
            <p class="text-hpah-text-light">Search for "PetDesk" in the App Store or Google Play</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-8 h-8 bg-hpah-green text-white rounded-full flex items-center justify-center font-bold shrink-0">2</div>
          <div>
            <p class="font-semibold text-hpah-text">Create your account</p>
            <p class="text-hpah-text-light">Use the email address we have on file for you to link your pet's records</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-8 h-8 bg-hpah-green text-white rounded-full flex items-center justify-center font-bold shrink-0">3</div>
          <div>
            <p class="font-semibold text-hpah-text">Find Healthy Paws Animal Hospital</p>
            <p class="text-hpah-text-light">Search for our practice name or use our zip code (60156) to locate us</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="w-8 h-8 bg-hpah-green text-white rounded-full flex items-center justify-center font-bold shrink-0">4</div>
          <div>
            <p class="font-semibold text-hpah-text">Start managing your pet's health</p>
            <p class="text-hpah-text-light">View records, request appointments, and message our team right away</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Links -->
  <section class="py-12 border-t border-gray-100">
    <div class="container max-w-3xl">
      <h3 class="text-lg font-bold mb-4">Related Pages</h3>
      <div class="flex flex-wrap gap-3">
        <a href="/schedule/" class="text-hpah-green hover:underline text-sm">Schedule Online</a>
        <span class="text-gray-300">|</span>
        <a href="/prescription-refills/" class="text-hpah-green hover:underline text-sm">Prescription Refills</a>
        <span class="text-gray-300">|</span>
        <a href="/contact/" class="text-hpah-green hover:underline text-sm">Contact Us</a>
        <span class="text-gray-300">|</span>
        <a href="/forms/" class="text-hpah-green hover:underline text-sm">Patient Forms</a>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
