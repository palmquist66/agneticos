---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business } from '../data/business';

import heroImg from '../assets/images/hero/banner-img-8.jpg';
import appScreenshot from '../assets/images/brand/our-app-image.png';
import appStoreBadge from '../assets/images/brand/app-store-badge-168px-h.png';
import playBadge from '../assets/images/brand/play-badge-168px-h.png';
---

<BaseLayout
  title="Our App | Healthy Paws Animal Hospital"
  description="Download the PetPage by AllyDVM app for Healthy Paws Animal Hospital. Update info, request refills and appointments, get reminders, and more."
>
  <!-- Hero Banner -->
  <section class="hero-banner">
    <div class="absolute inset-0">
      <Image
        src={heroImg}
        alt="Healthy Paws Animal Hospital"
        class="w-full h-full object-cover"
        loading="eager"
        widths={[640, 960, 1280, 1920]}
      />
      <div class="absolute inset-0" style="background: rgba(0,0,0,0.4);"></div>
    </div>
    <div class="container relative z-10 text-center">
      <h1 class="text-4xl lg:text-5xl text-white mb-4">Our App</h1>
      <p class="text-lg text-white/90 max-w-2xl mx-auto">
        With our all-new PetPage by AllyDVM app, we're simplifying your pet care.
      </p>
    </div>
  </section>

  <!-- App Content -->
  <section class="py-20">
    <div class="container" style="max-width: 960px;">
      <div class="flex flex-col md:flex-row gap-12 items-center">
        <div class="md:w-1/2">
          <Image
            src={appScreenshot}
            alt="A dog looking at a stethoscope"
            width={500}
            class="w-full max-w-sm mx-auto"
          />
        </div>
        <div class="md:w-1/2">
          <h2 class="mb-6">With our all-new PetPage by <a href="https://practices.allydvm.com/?practice=healthypawsah">AllyDVM app</a>, we're simplifying your pet care.</h2>
          <p class="font-bold text-hpah-text mb-4">We're excited to provide an improved experience with all-new digital self-serve tools:</p>
          <ul class="space-y-3 text-hpah-text-light">
            <li class="flex gap-3 items-start">
              <span class="text-hpah-green font-bold mt-0.5">&#10003;</span>
              <span>Update your information, request refills, and request appointments – even when our office is closed</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="text-hpah-green font-bold mt-0.5">&#10003;</span>
              <span>Easy registration and login process</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="text-hpah-green font-bold mt-0.5">&#10003;</span>
              <span>Pet ID you can customize and share</span>
            </li>
            <li class="flex gap-3 items-start">
              <span class="text-hpah-green font-bold mt-0.5">&#10003;</span>
              <span>Set up and receive in-app notifications and reminders</span>
            </li>
          </ul>
          <p class="mt-6 text-hpah-text-light">The PetPage app is available for download today!</p>
          <div class="flex flex-col sm:flex-row gap-4 mt-6">
            <a href="https://apps.apple.com/us/app/petpage/id6443568264" aria-label="Download on the App Store">
              <Image src={appStoreBadge} alt="Download on the App Store" height={56} class="h-14 w-auto" />
            </a>
            <a href="https://play.google.com/store/apps/details?id=com.allydvm.ast" aria-label="Get it on Google Play">
              <Image src={playBadge} alt="Get it on Google Play" height={56} class="h-14 w-auto" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
