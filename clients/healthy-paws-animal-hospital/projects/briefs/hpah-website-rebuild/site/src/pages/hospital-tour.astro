---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business } from '../data/business';

import exteriorPhoto from '../assets/images/facility/Healthy-Paws-Office-Front-Offset.jpg';
import photo1 from '../assets/images/facility/HealthyPaws014053-1-768x512-1.jpg';
import photo2 from '../assets/images/facility/Exam-Room.jpg';
import photo3 from '../assets/images/facility/DSC_0213.jpg';
import photo4 from '../assets/images/facility/SurgerySuite.jpg';
import photo5 from '../assets/images/facility/Pharmacy.jpg';
import photo6 from '../assets/images/facility/Lobby-Room-1.jpg';
import photo7 from '../assets/images/facility/Lobby-Room.jpg';
import photo8 from '../assets/images/facility/HealthyPaws014134-1-768x512-1.jpg';

const galleryPhotos = [
  { image: photo1, alt: 'A vet holding a dog' },
  { image: photo2, alt: 'Exam Room' },
  { image: photo3, alt: 'A computer screen on a desk' },
  { image: photo4, alt: 'Surgery Suite' },
  { image: photo5, alt: 'Pharmacy Room' },
  { image: photo6, alt: 'Lobby Room' },
  { image: photo7, alt: 'Lobby Room' },
  { image: exteriorPhoto, alt: 'Healthy Paws Animal Hospital Front view' },
  { image: photo8, alt: 'A person sitting at a desk working on a computer' },
];
---

<BaseLayout
  title="Take a Tour | Healthy Paws Animal Hospital"
  description="Take a virtual tour of Healthy Paws Animal Hospital in Lake in the Hills, IL. See our exam rooms, surgery suite, pharmacy, lobby, and more. We have an open-door policy."
>
  <!-- Hero Banner -->
  <section class="hero-banner">
    <div class="absolute inset-0">
      <Image
        src={exteriorPhoto}
        alt="Healthy Paws Animal Hospital building exterior"
        class="w-full h-full object-cover"
        loading="eager"
        widths={[640, 960, 1280, 1920]}
      />
      <div class="absolute inset-0" style="background: rgba(0,0,0,0.4);"></div>
    </div>
    <div class="container relative z-10 text-center">
      <h1 class="text-4xl lg:text-5xl text-white mb-4">Take a Tour</h1>
      <p class="text-lg text-white/90 max-w-2xl mx-auto">
        We hope to meet you and your animal companion soon. Before you come in for an appointment, take a virtual tour of our facility!
      </p>
    </div>
  </section>

  <!-- Tour Gallery -->
  <section class="py-20">
    <div class="container max-w-5xl">
      <p class="text-center text-lg text-hpah-text-light mb-12">
        Take a tour online or in person. We have an open-door policy.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {galleryPhotos.map((photo) => (
          <div class="divi-card">
            <Image
              src={photo.image}
              alt={photo.alt}
              class="w-full aspect-[4/3] object-cover"
              widths={[320, 480]}
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</BaseLayout>
