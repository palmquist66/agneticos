---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { services } from '../data/business';
---

<BaseLayout
  title="Veterinary Services in Lake in the Hills, IL | Healthy Paws Animal Hospital"
  description="Comprehensive veterinary services in Lake in the Hills, IL. Wellness exams, dental care, surgery, gentle low-stress care, and more. Call (815) 322-5400."
>
  <!-- Hero -->
  <section class="bg-hpah-green-light py-16">
    <div class="container">
      <div class="max-w-3xl">
        <p class="text-hpah-green font-bold text-sm uppercase tracking-wider mb-3">
          Our Services
        </p>
        <h1 class="text-4xl lg:text-5xl mb-4">Comprehensive Veterinary Care for Every Stage of Your Pet's Life</h1>
        <p class="text-lg text-hpah-text-light">
          From your pet's first wellness exam to their senior years, Healthy Paws Animal Hospital provides the full spectrum of veterinary services under one roof. Every service is delivered with our gentle, low-stress approach, a commitment to education, and the personal attention that comes from being a privately owned practice.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-20">
    <div class="container">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map((service) => (
          <a
            href={`/${service.slug}/`}
            class="group block bg-white rounded-lg border border-gray-200 p-6 hover:border-hpah-green hover:shadow-lg transition-all"
          >
            <span class="text-3xl mb-3 block">{service.icon}</span>
            <h2 class="text-lg font-bold mb-2 group-hover:text-hpah-green transition-colors">{service.name}</h2>
            <p class="text-sm text-hpah-text-light">{service.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Our Approach Matters -->
  <section class="py-16 bg-hpah-bg-warm">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="mb-6">Every Service, Delivered the Healthy Paws Way</h2>
        <p class="text-hpah-text-light text-lg mb-8">
          What makes our care different isn't just what we do — it's how we do it. Every service at Healthy Paws is guided by the same principles.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <span class="text-3xl mb-3 block">💚</span>
          <h3 class="text-lg font-bold mb-2">Gentle, Low-Stress Care</h3>
          <p class="text-sm text-hpah-text-light">
            Our entire team is trained in gentle handling to reduce fear, anxiety, and stress during every procedure and visit. Your pet's emotional well-being matters as much as their physical health.
          </p>
        </div>
        <div class="text-center">
          <span class="text-3xl mb-3 block">📚</span>
          <h3 class="text-lg font-bold mb-2">Education First</h3>
          <p class="text-sm text-hpah-text-light">
            We explain the "why" behind every recommendation. When you understand your pet's health, you can make the best decisions for their care.
          </p>
        </div>
        <div class="text-center">
          <span class="text-3xl mb-3 block">🏠</span>
          <h3 class="text-lg font-bold mb-2">Privately Owned</h3>
          <p class="text-sm text-hpah-text-light">
            No corporate protocols or profit mandates. Every recommendation is made with your pet's best interest in mind — always.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CTA
    heading="Not Sure Which Service Your Pet Needs?"
    text="Give us a call and our team will help you determine the right care for your pet's situation. We're always happy to answer questions."
  />
</BaseLayout>
