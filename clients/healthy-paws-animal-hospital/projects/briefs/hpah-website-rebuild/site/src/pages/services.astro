---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { services } from '../data/business';

// Service card images (matching WP service index)
import puppyCareImg from '../assets/images/services/puppy-care.png';
import adultCareImg from '../assets/images/services/adult-care.png';
import seniorCareImg from '../assets/images/services/senior-care.png';
import fearfulFriendsImg from '../assets/images/services/fearful-friends.png';
import dentistryImg from '../assets/images/services/Dentistry-2.png';
import surgeryImg from '../assets/images/services/Surgery.jpg';
import spayNeuterImg from '../assets/images/services/spay-3.png';

// Hero image
import heroImg from '../assets/images/hero/banner-img-5.jpg';

const featuredServices = [
  {
    name: 'Puppy and Kitten Care',
    image: puppyCareImg,
    alt: 'Puppy sitting on vet\'s lap',
    description: 'Bringing a new puppy or kitten into your home is an exhilarating experience filled with joy, anticipation, funny moments, and sometimes frustration. At Healthy Paws Animal Hospital, we appreciate the excitement and challenges that come with this journey. As your family veterinarian, we are dedicated to supporting you through every phase, ensuring the health and happiness of your newest family member and setting everyone up for success.',
    href: '/general-care-lake-in-the-hills-il/',
  },
  {
    name: 'Adult Care',
    image: adultCareImg,
    alt: 'Gnocchi the cat at the vet',
    description: 'Keeping your adult pet healthy starts with consistent preventive care. As dogs and cats move out of the puppy or kitten stage, their medical needs change, and annual wellness exams become essential for maintaining long-term health. Our Adult Wellness FAQ\'s are designed to answer the most common questions we hear from pet owners and help you understand what to expect at your pet\'s checkups, which services are recommended at this life stage, and how we support your pet\'s ongoing health and happiness.',
    href: '/wellness-exams-lake-in-the-hills-il/',
  },
  {
    name: 'Senior Care',
    image: seniorCareImg,
    alt: 'Heather with a small dog',
    description: 'Keeping senior pets healthy starts with a proactive approach \u2013 we are striving to identify issues before they become life changing problems. As dogs and cats enter their senior years, subtle changes in their health can occur quickly and may be easy to miss at home or only found on bloodwork or in x-rays. Senior wellness exams focus on early detection, monitoring age-related changes, and maintaining comfort and quality of life.',
    href: '/senior-pet-care-lake-in-the-hills-il/',
  },
  {
    name: 'Fearful Friends',
    image: fearfulFriendsImg,
    alt: 'Deuce the Great Dane wearing a muzzle at the vet',
    description: 'Many of our patients experience fear, anxiety, or panic at the veterinary office. If we do not acknowledge our patient\'s emotions, aggression can be the outcome \u2013 especially if a pet does not feel like there is any other option. This is why, as veterinary professionals, we monitor our patients closely looking for signs of progressing anxiety. At Healthy Paws we do a variety of things to read a pet\'s emotional state thus allowing us to provide as relaxing of an environment as possible throughout a visit.',
    href: '/low-stress-vet-lake-in-the-hills-il/',
  },
  {
    name: 'End of Life Care',
    image: seniorCareImg,
    alt: 'Compassionate end of life care for pets',
    description: 'We understand that one of the most difficult decisions a pet owner may face is considering end-of-life care for a beloved companion. As your veterinary family, we are here to support you with compassion, respect, and understanding during this emotional time.',
    href: '/end-of-life-care/',
  },
  {
    name: 'Pet Dentistry',
    image: dentistryImg,
    alt: 'Pet dental care at Healthy Paws Animal Hospital',
    description: 'Dental disease is the most common health problem we see in dogs and cats and yet one of the most preventable. At Healthy Paws Animal Hospital, our approach to dentistry goes beyond a "cleaning." We assess, diagnose, treat, and educate so that you and your pet leave better off than when you arrived.',
    href: '/dental-care/',
  },
  {
    name: 'Pet Surgery',
    image: surgeryImg,
    alt: 'Pet surgery at Healthy Paws Animal Hospital',
    description: 'When your pet needs surgery, you deserve to know exactly what is happening and why. At Healthy Paws Animal Hospital, every surgical patient receives individualized anesthetic protocols, dedicated technician monitoring, and proactive pain management from the moment they arrive to the moment they go home.',
    href: '/surgery/',
  },
  {
    name: 'Spay & Neuter',
    image: spayNeuterImg,
    alt: 'Dog running with tennis ball',
    description: 'Spaying or neutering your pet is one of the most meaningful decisions you can make for their long-term health. At Healthy Paws Animal Hospital, these procedures are performed with the same individualized care, thorough monitoring, and proactive pain management we bring to every surgical patient.',
    href: '/spay-neuter-lake-in-the-hills-il/',
  },
];

// Additional services not in the featured cards
const featuredSlugs = [
  'general-care-lake-in-the-hills-il',
  'wellness-exams-lake-in-the-hills-il',
  'senior-pet-care-lake-in-the-hills-il',
  'low-stress-vet-lake-in-the-hills-il',
  'dental-care',
  'surgery',
  'spay-neuter-lake-in-the-hills-il',
  'end-of-life-care',
];
const additionalServices = services.filter((s) => !featuredSlugs.includes(s.slug));
---

<BaseLayout
  title="Veterinary Services in Lake in the Hills, IL | Healthy Paws Animal Hospital"
  description="Comprehensive veterinary services in Lake in the Hills, IL — wellness exams, dental care, surgery, senior care, gentle low-stress handling, and more. Call (815) 322-5400."
>
  <!-- Hero Banner -->
  <section class="hero-banner">
    <div class="absolute inset-0">
      <Image
        src={heroImg}
        alt="Veterinary services at Healthy Paws Animal Hospital"
        class="w-full h-full object-cover"
        loading="eager"
        widths={[640, 960, 1280, 1920]}
      />
      <div class="absolute inset-0" style="background: rgba(0,0,0,0.45);"></div>
    </div>
    <div class="container relative z-10 text-center">
      <h1 class="text-4xl lg:text-5xl text-white mb-4">Veterinary Services</h1>
      <p class="text-lg text-white/90 max-w-2xl mx-auto">
        At <a href="/about/" class="text-white underline">Healthy Paws Animal Hospital</a>, we take pride in offering a comprehensive range of veterinary services to cater to all your pet's needs.
      </p>
    </div>
  </section>

  <!-- Featured Service Cards (matching WP layout) -->
  <section class="py-20">
    <div class="container" style="max-width: 960px;">
      <div class="space-y-10">
        {featuredServices.map((service) => (
          <div class="divi-card-green">
            <div class="flex flex-col md:flex-row">
              <div class="md:w-2/5">
                <Image
                  src={service.image}
                  alt={service.alt}
                  class="w-full h-full object-cover"
                  style="min-height: 250px;"
                  widths={[320, 480]}
                />
              </div>
              <div class="md:w-3/5 p-8 flex flex-col justify-center">
                <h3 class="text-2xl mb-3">{service.name}</h3>
                <p class="text-hpah-text-light mb-4">{service.description}</p>
                <div>
                  <a href={service.href} class="btn-primary">Learn More</a>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Additional Services -->
  {additionalServices.length > 0 && (
    <section class="py-16 bg-hpah-bg-warm">
      <div class="container">
        <div class="text-center max-w-3xl mx-auto mb-12">
          <h2>More Services</h2>
          <p class="text-hpah-text-light mt-4">
            We also provide these specialized services to support your pet's health and well-being.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-4xl mx-auto">
          {additionalServices.map((service) => (
            <a
              href={`/${service.slug}/`}
              class="group block bg-white rounded-lg border border-gray-200 p-6 hover:border-hpah-green hover:shadow-lg transition-all"
            >
              <span class="text-3xl mb-3 block">{service.icon}</span>
              <h3 class="text-lg font-bold mb-2 group-hover:text-hpah-green transition-colors">{service.name}</h3>
              <p class="text-sm text-hpah-text-light">{service.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <CTA
    heading="Not Sure Which Service Your Pet Needs?"
    text="Give us a call and our team will help you determine the right care for your pet's situation. We're always happy to answer questions."
  />
</BaseLayout>
