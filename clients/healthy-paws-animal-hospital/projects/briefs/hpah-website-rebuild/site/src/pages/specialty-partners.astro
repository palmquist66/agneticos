---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import { business } from '../data/business';

import heroImg from '../assets/images/hero/banner-img-13.jpg';
---

<BaseLayout
  title="Specialty & Emergency Partners | Healthy Paws Animal Hospital"
  description="After-hours veterinary emergency centers and poison control contacts recommended by Healthy Paws Animal Hospital in Lake in the Hills, IL."
>
  <!-- Hero Banner -->
  <section class="hero-banner">
    <div class="absolute inset-0">
      <Image
        src={heroImg}
        alt="Healthy Paws Animal Hospital"
        class="w-full h-full object-cover"
        loading="eager"
        widths={[640, 960, 1280, 1920]}
      />
      <div class="absolute inset-0" style="background: rgba(0,0,0,0.4);"></div>
    </div>
    <div class="container relative z-10 text-center">
      <h1 class="text-4xl lg:text-5xl text-white mb-4">Specialty & Emergency Partners</h1>
      <p class="text-lg text-white/90 max-w-2xl mx-auto">
        For after-hours veterinary emergencies, please contact one of the following local emergency centers.
      </p>
    </div>
  </section>

  <!-- Emergencies -->
  <section class="py-16 lg:py-20">
    <div class="container" style="max-width: 900px;">
      <h2 class="text-3xl mb-8">Emergencies</h2>
      <p class="text-hpah-text-light mb-10">For an after-hours veterinary medical crisis, please call the following local emergency centers:</p>

      <div class="space-y-8">

        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-bold mb-2">Companion Animal Specialty and Emergency</h3>
          <p class="text-hpah-text-light">1095 Pingree Road<br/>Crystal Lake, Illinois 60014</p>
          <p class="mt-2">Phone: <a href="tel:815-479-9119" class="text-hpah-green font-semibold">(815) 479-9119</a></p>
          <p class="text-sm text-hpah-text-light">Fax: 847-854-9119</p>
          <a href="https://www.casehospital.com/" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:underline text-sm mt-2 inline-block">Visit Website &rarr;</a>
        </div>

        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-bold mb-2">Veterinary Specialty Center (VSC)</h3>
          <p class="text-hpah-text-light">2051 Waukegan Rd.<br/>Bannockburn, IL 60015</p>
          <p class="mt-2">Phone: <a href="tel:847-459-7535" class="text-hpah-green font-semibold">(847) 459-7535</a></p>
          <p class="text-sm text-hpah-text-light">Open 24/7</p>
          <a href="http://www.vetspecialty.com/" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:underline text-sm mt-2 inline-block">Visit Website &rarr;</a>
        </div>

        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-bold mb-2">VCA Aurora</h3>
          <p class="text-hpah-text-light">2600 W Galena Blvd<br/>Aurora, IL 60506</p>
          <p class="mt-2">Phone: <a href="tel:630-301-6100" class="text-hpah-green font-semibold">(630) 301-6100</a></p>
          <p class="text-sm text-hpah-text-light">Open 24/7</p>
          <a href="https://www.vcahospitals.com/aurora" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:underline text-sm mt-2 inline-block">Visit Website &rarr;</a>
        </div>

        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-bold mb-2">Thrive Pet Healthcare Specialists Hoffman Estates</h3>
          <p class="text-hpah-text-light">2700 W Higgins Rd<br/>Hoffman Estates, IL 60169</p>
          <p class="mt-2">Phone: <a href="tel:618-495-5010" class="text-hpah-green font-semibold">(618) 495-5010</a> or <a href="tel:618-852-1732" class="text-hpah-green font-semibold">(618) 852-1732</a></p>
          <p class="text-sm text-hpah-text-light">Open 24/7</p>
          <a href="https://www.thrivepetcare.com/" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:underline text-sm mt-2 inline-block">Visit Website &rarr;</a>
        </div>

        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-bold mb-2">Blue Pearl Pet Hospital</h3>
          <p class="text-hpah-text-light">820 W. Frontage Road<br/>Northfield, IL 60093</p>
          <p class="mt-2">Phone: <a href="tel:847-564-5775" class="text-hpah-green font-semibold">(847) 564-5775</a></p>
          <p class="text-sm text-hpah-text-light">Open 24/7</p>
          <a href="https://bluepearlvet.com/hospital/northfield-il/" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:underline text-sm mt-2 inline-block">Visit Website &rarr;</a>
        </div>

        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-bold mb-2">Chicago MedVet</h3>
          <p class="text-hpah-text-light">3305 N. California Avenue<br/>Chicago, IL 60618</p>
          <p class="mt-2">Phone: <a href="tel:773-281-7110" class="text-hpah-green font-semibold">(773) 281-7110</a></p>
          <p class="text-sm text-hpah-text-light">Open 24/7</p>
          <a href="https://www.medvet.com/location/chicago/" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:underline text-sm mt-2 inline-block">Visit Website &rarr;</a>
        </div>

        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-bold mb-2">Elgin Urgent Vet Clinic</h3>
          <p class="text-hpah-text-light">1190 South Randall Road, Suite 104<br/>Elgin, IL 60123</p>
          <p class="mt-2">Phone: <a href="tel:630-221-6500" class="text-hpah-green font-semibold">(630) 221-6500</a></p>
          <p class="text-sm text-hpah-text-light">Mon-Fri 3pm-11pm; Sat & Sun 10am-8pm</p>
          <a href="https://www.urgentvet.com/" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:underline text-sm mt-2 inline-block">Visit Website &rarr;</a>
        </div>

        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-bold mb-2">Veterinary Emergency Group Buffalo Grove</h3>
          <p class="text-hpah-text-light">43 McHenry Rd.<br/>Buffalo Grove, IL 60089</p>
          <p class="mt-2">Phone: <a href="tel:847-754-3996" class="text-hpah-green font-semibold">(847) 754-3996</a></p>
          <p class="text-sm text-hpah-text-light">Open 24/7</p>
          <a href="https://www.veg.com/" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:underline text-sm mt-2 inline-block">Visit Website &rarr;</a>
        </div>

        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-bold mb-2">Elk Grove Veterinary Specialty and Emergency (Thrive Pet Healthcare Elk Grove)</h3>
          <p class="text-hpah-text-light">1050 Bonaventure Dr.<br/>Elk Grove Village, IL 60007</p>
          <p class="mt-2">Phone: <a href="tel:847-584-0200" class="text-hpah-green font-semibold">(847) 584-0200</a> or <a href="tel:847-558-6791" class="text-hpah-green font-semibold">(847) 558-6791</a></p>
          <p class="text-sm text-hpah-text-light">Open 24/7</p>
          <a href="https://www.thrivepetcare.com/" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:underline text-sm mt-2 inline-block">Visit Website &rarr;</a>
        </div>

        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-bold mb-2">Premier Veterinary Group Mundelein</h3>
          <p class="text-hpah-text-light">1385 Townline Rd<br/>Mundelein, IL 60060</p>
          <p class="mt-2">Phone: <a href="tel:847-548-5300" class="text-hpah-green font-semibold">(847) 548-5300</a></p>
          <p class="text-sm text-hpah-text-light">Open 7am-midnight</p>
          <a href="https://www.premiervets.net/" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:underline text-sm mt-2 inline-block">Visit Website &rarr;</a>
        </div>

      </div>
    </div>
  </section>

  <!-- Poison Control -->
  <section class="py-16" style="background-color: #DEDEE9;">
    <div class="container" style="max-width: 900px;">
      <h2 class="text-3xl mb-4">Poison Control</h2>
      <p class="text-hpah-text-light mb-8">If you believe your pet may have ingested a potentially poisonous substance, contact Pet Poison Control for immediate guidance. *Fee associated</p>

      <div class="space-y-8">
        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-bold mb-2">Pet Poison Helpline</h3>
          <p class="text-hpah-text-light">3600 American Boulevard W., Suite 725<br/>Bloomington, MN 55431</p>
          <p class="mt-2">Phone: <a href="tel:855-764-7661" class="text-hpah-green font-semibold">(855) 764-7661</a></p>
          <a href="https://www.petpoisonhelpline.com/" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:underline text-sm mt-2 inline-block">Visit Website &rarr;</a>
        </div>

        <div class="bg-white rounded-lg p-6 border border-gray-200">
          <h3 class="text-lg font-bold mb-2">ASPCA Poison Control</h3>
          <p class="text-hpah-text-light">424 E. 92nd St<br/>New York, NY 10128-6804</p>
          <p class="mt-2">Phone: <a href="tel:888-426-4435" class="text-hpah-green font-semibold">(888) 426-4435</a></p>
          <p class="text-sm text-hpah-text-light">Open 24/7</p>
          <a href="https://www.aspca.org/pet-care/aspca-poison-control" target="_blank" rel="noopener noreferrer" class="text-hpah-green hover:underline text-sm mt-2 inline-block">Visit Website &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <CTA heading="Non-Emergency Questions?" text="For non-urgent concerns during business hours, call us directly. We're happy to help determine if your pet needs emergency care." />
</BaseLayout>
