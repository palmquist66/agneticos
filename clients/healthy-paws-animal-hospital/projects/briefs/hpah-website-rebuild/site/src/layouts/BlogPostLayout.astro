---
import BaseLayout from './BaseLayout.astro';
import Schema from '../components/Schema.astro';
import CTA from '../components/CTA.astro';
import { business } from '../data/business';

interface Props {
  title: string;
  description: string;
  date: string;
  updated?: string;
  author: string;
  categories: string[];
  tags: string[];
  image?: string;
}

const {
  title,
  description,
  date,
  updated,
  author,
  categories,
  tags,
  image,
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const formattedUpdated = updated
  ? new Date(updated).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const pageUrl = `${business.website}${Astro.url.pathname}`;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description,
  datePublished: date,
  ...(updated && { dateModified: updated }),
  author: {
    '@type': 'Organization',
    name: author,
    url: business.website,
  },
  publisher: {
    '@type': 'VeterinaryHospital',
    name: business.name,
    url: business.website,
    logo: {
      '@type': 'ImageObject',
      url: business.logo,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': pageUrl,
  },
  ...(image && { image: image }),
  keywords: tags.join(', '),
};
---

<BaseLayout title={`${title} | Pet Health Blog`} description={description}>
  <script slot="schema" type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

  <!-- Article Header -->
  <section class="bg-hpah-green-light py-12 lg:py-16">
    <div class="container">
      <div class="max-w-3xl">
        <!-- Category badges -->
        {categories.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-4">
            {categories.map((category) => (
              <a
                href={`/blog/category/${category.toLowerCase().replace(/\s+/g, '-')}/`}
                class="inline-block px-3 py-1 bg-hpah-green text-white text-xs font-bold uppercase tracking-wider rounded-full hover:bg-hpah-green-dark transition-colors"
              >
                {category}
              </a>
            ))}
          </div>
        )}

        <h1 class="text-3xl lg:text-4xl mb-4">{title}</h1>

        <div class="flex flex-wrap items-center gap-4 text-sm text-hpah-text-light">
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <time datetime={date}>{formattedDate}</time>
          </span>
          {formattedUpdated && (
            <span class="text-xs">(Updated: {formattedUpdated})</span>
          )}
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            {author}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- Article Body -->
  <section class="py-12 lg:py-16">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main Content -->
        <article class="lg:col-span-2 prose">
          <slot />
        </article>

        <!-- Sidebar -->
        <aside class="space-y-8">
          <!-- Quick Contact -->
          <div class="bg-hpah-green-light rounded-lg p-6">
            <h3 class="text-lg font-bold mb-3">Have Questions?</h3>
            <p class="text-sm text-hpah-text-light mb-4">
              Our team is always happy to help with your pet health questions. Give us a call or schedule a visit.
            </p>
            <a href={`tel:${business.phoneRaw}`} class="btn-primary w-full justify-center text-sm">
              Call {business.phone}
            </a>
          </div>

          <!-- Tags -->
          {tags.length > 0 && (
            <div class="bg-white rounded-lg border border-gray-200 p-6">
              <h3 class="text-lg font-bold mb-3">Topics</h3>
              <div class="flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <span class="inline-block px-3 py-1 bg-gray-100 text-hpah-text-light text-xs rounded-full">
                    {tag}
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Back to Blog -->
          <div class="bg-white rounded-lg border border-gray-200 p-6">
            <h3 class="text-lg font-bold mb-3">More Articles</h3>
            <p class="text-sm text-hpah-text-light mb-4">
              Browse more pet health articles from our team.
            </p>
            <a href="/blog/" class="btn-secondary w-full justify-center text-sm">
              View All Posts
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <CTA
    heading="Questions About Your Pet's Health?"
    text="Our veterinary team is here to help. Schedule a visit or call us to discuss your pet's needs."
  />
</BaseLayout>
