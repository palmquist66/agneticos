---
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import FAQSchema from '../components/FAQSchema.astro';
import ServiceSchema from '../components/ServiceSchema.astro';
import { business } from '../data/business';

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  serviceName: string;
  serviceDescription: string;
  heroSubtitle?: string;
  heroImage?: ImageMetadata;
  faqs: FAQ[];
  relatedServices?: string[];
}

const {
  title,
  description,
  serviceName,
  serviceDescription,
  heroSubtitle = `Serving ${business.serviceAreas.slice(0, 4).join(', ')}, and surrounding communities`,
  heroImage,
  faqs,
} = Astro.props;

const pageUrl = `${business.website}${Astro.url.pathname}`;
const h1 = title.split('|')[0].trim();
---

<BaseLayout title={title} description={description}>
  <ServiceSchema
    slot="schema"
    name={serviceName}
    description={serviceDescription}
    url={pageUrl}
  />

  <!-- Hero -->
  <section class="hero-banner">
    {heroImage && (
      <div class="absolute inset-0">
        <Image
          src={heroImage}
          alt={`${serviceName} at Healthy Paws Animal Hospital`}
          class="w-full h-full object-cover"
          loading="eager"
          widths={[640, 960, 1280, 1920]}
        />
        <div class="absolute inset-0" style="background: rgba(0,0,0,0.5);"></div>
      </div>
    )}
    <div class="container relative z-10 text-center">
      <h1 class="text-4xl lg:text-5xl text-white mb-3">{h1}</h1>
      <p class="text-lg text-white/90 max-w-2xl mx-auto">{heroSubtitle}</p>
    </div>
  </section>

  <!-- Main Content: image left, content + FAQ right -->
  <section class="py-16">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
        {heroImage && (
          <div class="lg:col-span-2">
            <Image
              src={heroImage}
              alt={serviceName}
              widths={[400, 600, 800]}
              class="w-full object-cover divi-card-green"
            />
          </div>
        )}
        <div class:list={['prose', heroImage ? 'lg:col-span-3' : 'lg:col-span-5']}>
          <slot />
          {faqs.length > 0 && (
            <div class="space-y-4 mt-8">
              {faqs.map((faq) => (
                <details class="group rounded-lg overflow-hidden" style="background-color: var(--color-hpah-toggle-bg); border-left: 4px solid var(--color-hpah-green);">
                  <summary class="flex justify-between items-center cursor-pointer p-5 font-bold text-hpah-text hover:text-hpah-green transition-colors list-none" style="font-family: var(--font-narrow);">
                    <span>{faq.question}</span>
                    <svg class="w-5 h-5 flex-shrink-0 ml-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </summary>
                  <div class="px-5 pb-5 text-hpah-text-light leading-relaxed">
                    {faq.answer}
                  </div>
                </details>
              ))}
            </div>
          )}
        </div>
      </div>
    </div>
  </section>

  {faqs.length > 0 && <FAQSchema faqs={faqs} />}
</BaseLayout>
