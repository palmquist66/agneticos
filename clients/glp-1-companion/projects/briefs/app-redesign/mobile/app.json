{
  "expo": {
    "name": "GLP-1 Companion",
    "slug": "glp1-companion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "glp1companion",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F5F5A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.glp1companion.app",
      "infoPlist": {},
      "entitlements": {
        "aps-environment": "production"
      }
    },
    "android": {
      "package": "com.glp1companion.app",
      "permissions": [
        "android.permission.health.READ_WEIGHT",
        "android.permission.health.READ_BLOOD_GLUCOSE",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0F5F5A",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0F5F5A"
        }
      ],
      [
        "@kingstinct/react-native-healthkit",
        {
          "NSHealthShareUsageDescription": "GLP-1 Companion reads your weight, glucose, steps, and active energy from Apple Health to track progress and surface insights.",
          "NSHealthUpdateUsageDescription": "GLP-1 Companion writes medication doses to Apple Health so your data stays in sync.",
          "background": true
        }
      ],
      "react-native-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 26
          }
        }
      ],
      "./plugins/withHealthConnectRationale"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
